							case 5: CASH[i] = 2750;
							case 4: CASH[i] = 2400;
							case 3: CASH[i] = 1900;
							case 2: CASH[i] = 1450;
							case 1: CASH[i] = 1330;
						}
					}
					if(PlayerInfo[i][pMember] == 9 && PlayerInfo[i][pUnit] == 1)
					{
						switch(PlayerInfo[i][pRang])
						{
							case 10: CASH[i] = 5200;
							case 9: CASH[i] = 4600;
							case 8: CASH[i] = 3200;
							case 7: CASH[i] = 3200;
							case 6: CASH[i] = 3200;
							case 5: CASH[i] = 3200;
							case 4: CASH[i] = 3200;
							case 3: CASH[i] = 1750;
							case 2: CASH[i] = 1350;
							case 1: CASH[i] = 940;
						}
					}
					CASH[i] += PlayerInfo[i][pCash];
					PlayerInfo[i][pCash] = 0;
					PlayerInfo[i][pBank] += CASH[i];
				}
				if(CASH[i] > 0)
				{
				format(query, sizeof(query), "Зарплата: {00CC00}%d$", CASH[i]);
				SendClientMessage(i, COLOR_WHITE, query);
				}
				if(CASH[i] <= 0 && PlayerInfo[i][pAdmin] == 0) SendClientMessage(i, COLOR_WHITE, "Зарплата: {FF6347}0$");
				if(login_check[i] == true && PlayerInfo[i][pAFK] == false) format(query, sizeof(query), "Текущий баланс счёта: {00CC00}%d$", PlayerInfo[i][pBank]);
				if(PlayerInfo[i][pBank] == 0 && PlayerInfo[i][pAFK] == false) format(query, sizeof(query), "Текущий баланс счёта: {FF6600}%d$", PlayerInfo[i][pBank]);
				SendClientMessage(i, COLOR_WHITE, query);
				PlayerInfo[i][pInGameTime] = 0;
				CASH[i] = 0;
			}
			SendClientMessage(i,COLOR_WHITE, "______________________");
			if(PlayerInfo[i][pLoto] == true)
			{
				new string[150], totalNums = 0;
				format(string, sizeof(string),"Начинаем лотерейный розыгрыш. Ваше счастливое число: %d%d%d",GetPVarInt(i, "LOTO1"),GetPVarInt(i, "LOTO2"),GetPVarInt(i, "LOTO3"));
