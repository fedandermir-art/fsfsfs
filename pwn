				if(GetPVarInt(i, "LOTO1") == lotoone)
				    totalNums++;
				if(GetPVarInt(i, "LOTO2") == lototwo)
				    totalNums++;
				if(GetPVarInt(i, "LOTO3") == lototri)
				    totalNums++;
				switch(totalNums)
				{
				    case 0:
				    {
						SendClientMessage(i, 0xFFFFFF, "К сожалению в вашем билете не совпала первая цифра");
						SendClientMessage(i, -1, "Не расстраивайтесь. В следующий раз Вам обязательно повезет");
				    }
				    case 1:
				    {
						SendClientMessage(i,0x5AB200FF, "В вашем билете совпало 1 цифра. Поздравляем, ваш выигрыш - 2.000$!");
