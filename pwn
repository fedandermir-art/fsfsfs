f_public GodModeTest(playerid, showid, Float: starthealth, Float: startarmour)
{
	new Float: currenthealth, Float: diff;
	GetPlayerHealth(playerid, currenthealth);
	diff = starthealth - currenthealth;
	format(query, sizeof(query),
	"{00FFFF}Пинг: %d\n\
		{B4B5B7}HP до взрыва: {FF6600}%.0f%%\n\
		{B4B5B7}HP после взрыва: {FF6600}%.0f%%\n\n\
		{B4B5B7}Разница: {FF6600}%.0f%%\n\n",
	GetPlayerPing(playerid),
	starthealth,
	currenthealth,
	diff
	);
	if(diff > 0.0) strcat(query, "{00CC00}GodMode не используется");
	else strcat(query, "{FF0000}GodMode возможно используется");
	ShowPlayerDialog(showid, 1277, DIALOG_STYLE_MSGBOX, PlayerInfo[playerid][pName], query, "Закрыть", "");
	PlayerInfo[playerid][pHealth] = starthealth;
	SetPlayerArmour(playerid, startarmour);
	SetPlayerHealth(playerid, starthealth);
}
