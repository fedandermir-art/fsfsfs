package org.exampl.npcplugin_shahed.data;

import java.io.Serializable;

public class NPCAbilities implements Serializable {

    // TNT способность
    private boolean tntEnabled = false;
    private int tntMinCount = 2;
    private int tntMaxCount = 4;
    private int tntInterval = 15; // секунды

    // Молния способность
    private boolean lightningEnabled = false;
    private int lightningInterval = 50; // секунды

    // Подброс способность
    private boolean launchEnabled = false;
    private int launchHeight = 30; // блоки
    private int launchInterval = 60; // секунды

    // Радиус активации способностей
    private int activationRadius = 32;

    // Конструктор
    public NPCAbilities() {}

    // Копирование
    public NPCAbilities copy() {
        NPCAbilities copy = new NPCAbilities();
        copy.tntEnabled = this.tntEnabled;
        copy.tntMinCount = this.tntMinCount;
        copy.tntMaxCount = this.tntMaxCount;
        copy.tntInterval = this.tntInterval;
        copy.lightningEnabled = this.lightningEnabled;
        copy.lightningInterval = this.lightningInterval;
        copy.launchEnabled = this.launchEnabled;
        copy.launchHeight = this.launchHeight;
        copy.launchInterval = this.launchInterval;
        copy.activationRadius = this.activationRadius;
        return copy;
    }

    // ===== TNT =====
    public boolean isTntEnabled() { return tntEnabled; }
    public void setTntEnabled(boolean enabled) { this.tntEnabled = enabled; }
    public int getTntMinCount() { return tntMinCount; }
    public void setTntMinCount(int count) { this.tntMinCount = Math.max(1, Math.min(10, count)); }
    public int getTntMaxCount() { return tntMaxCount; }
    public void setTntMaxCount(int count) { this.tntMaxCount = Math.max(1, Math.min(10, count)); }
    public int getTntInterval() { return tntInterval; }
    public void setTntInterval(int seconds) { this.tntInterval = Math.max(5, seconds); }

    // ===== Молния =====
    public boolean isLightningEnabled() { return lightningEnabled; }
    public void setLightningEnabled(boolean enabled) { this.lightningEnabled = enabled; }
    public int getLightningInterval() { return lightningInterval; }
    public void setLightningInterval(int seconds) { this.lightningInterval = Math.max(5, seconds); }

    // ===== Подброс =====
    public boolean isLaunchEnabled() { return launchEnabled; }
    public void setLaunchEnabled(boolean enabled) { this.launchEnabled = enabled; }
    public int getLaunchHeight() { return launchHeight; }
    public void setLaunchHeight(int height) { this.launchHeight = Math.max(5, Math.min(100, height)); }
    public int getLaunchInterval() { return launchInterval; }
    public void setLaunchInterval(int seconds) { this.launchInterval = Math.max(5, seconds); }

    // ===== Радиус =====
    public int getActivationRadius() { return activationRadius; }
    public void setActivationRadius(int radius) { this.activationRadius = Math.max(10, Math.min(64, radius)); }

    // Проверка - есть ли хоть одна способность
    public boolean hasAnyAbility() {
        return tntEnabled || lightningEnabled || launchEnabled;
    }
}


