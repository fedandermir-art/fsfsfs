package org.exampl.npcplugin_shahed.gui;

import org.exampl.npcplugin_shahed.CustomNPC;
import org.exampl.npcplugin_shahed.data.AirdropLoot;
import org.exampl.npcplugin_shahed.manager.AirdropManager;
import org.bukkit.Bukkit;
import org.bukkit.Material;
import org.bukkit.entity.Player;
import org.bukkit.event.EventHandler;
import org.bukkit.event.Listener;
import org.bukkit.event.inventory.InventoryClickEvent;
import org.bukkit.event.inventory.InventoryCloseEvent;
import org.bukkit.inventory.Inventory;
import org.bukkit.inventory.ItemStack;
import org.bukkit.inventory.meta.ItemMeta;

import java.util.*;

public class AirdropGUI implements Listener {

    private final CustomNPC plugin;
    private final AirdropManager airdropManager;

    private final String MAIN_MENU = "§6§lНастройка Аирдропа";
    private final String COMMON_MENU = "§7§lОбычный лут";
    private final String RARE_MENU = "§9§lРедкий лут";
    private final String LEGENDARY_MENU = "§6§lЛегендарный лут";

    private final Map<UUID, String> editingType = new HashMap<>();

    public AirdropGUI(CustomNPC plugin, AirdropManager airdropManager) {
        this.plugin = plugin;
        this.airdropManager = airdropManager;
        Bukkit.getPluginManager().registerEvents(this, plugin);
    }

    public void openMainMenu(Player player) {
        Inventory inv = Bukkit.createInventory(null, 27, MAIN_MENU);

        AirdropLoot common = airdropManager.getLoot("common");
        AirdropLoot rare = airdropManager.getLoot("rare");
        AirdropLoot legendary = airdropManager.getLoot("legendary");

        // Обычный
        ItemStack commonItem = createItem(Material.IRON_INGOT, "§7§lОбычный лут",
