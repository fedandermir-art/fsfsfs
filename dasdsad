    @EventHandler
    public void onInventoryClick(InventoryClickEvent event) {
        if (!(event.getWhoClicked() instanceof Player)) return;
        Player player = (Player) event.getWhoClicked();
        String title = event.getView().getTitle();

        if (title.equals(ABILITY_MENU)) {
            event.setCancelled(true);
            handleAbilityMenuClick(player, event.getSlot(), event.getClick());
        } else if (title.equals(TNT_MENU)) {
            event.setCancelled(true);
            handleTntMenuClick(player, event.getSlot(), event.getClick());
        } else if (title.equals(LIGHTNING_MENU)) {
            event.setCancelled(true);
            handleLightningMenuClick(player, event.getSlot(), event.getClick());
        } else if (title.equals(LAUNCH_MENU)) {
            event.setCancelled(true);
            handleLaunchMenuClick(player, event.getSlot(), event.getClick());
        }
    }

    private void handleAbilityMenuClick(Player player, int slot, ClickType click) {
        String presetName = editingPreset.get(player.getUniqueId());
        NPCPreset preset = findPreset(player, presetName);
        if (preset == null) return;

        NPCAbilities abilities = preset.getAbilities();

        switch (slot) {
            case 11: // TNT
                if (click.isLeftClick()) {
                    abilities.setTntEnabled(!abilities.isTntEnabled());
                    saveAndRefresh(player, presetName);
                } else if (click.isRightClick()) {
                    player.closeInventory();
                    Bukkit.getScheduler().runTaskLater(plugin, () -> openTntSettings(player), 1L);
                }
                break;

            case 13: // Lightning
                if (click.isLeftClick()) {
                    abilities.setLightningEnabled(!abilities.isLightningEnabled());
                    saveAndRefresh(player, presetName);
                } else if (click.isRightClick()) {
                    player.closeInventory();
                    Bukkit.getScheduler().runTaskLater(plugin, () -> openLightningSettings(player), 1L);
                }
                break;

            case 15: // Launch
                if (click.isLeftClick()) {
                    abilities.setLaunchEnabled(!abilities.isLaunchEnabled());
                    saveAndRefresh(player, presetName);
                } else if (click.isRightClick()) {
                    player.closeInventory();
                    Bukkit.getScheduler().runTaskLater(plugin, () -> openLaunchSettings(player), 1L);
                }
                break;

            case 31: // Radius
                int change = click.isShiftClick() ? 10 : 5;
                if (click.isLeftClick()) {
                    abilities.setActivationRadius(abilities.getActivationRadius() + change);
                } else if (click.isRightClick()) {
                    abilities.setActivationRadius(abilities.getActivationRadius() - change);
                }
                saveAndRefresh(player, presetName);
                break;

            case 36: // Back
                player.closeInventory();
                break;
        }
    }

    private void handleTntMenuClick(Player player, int slot, ClickType click) {
        String presetName = editingPreset.get(player.getUniqueId());
        NPCPreset preset = findPreset(player, presetName);
        if (preset == null) return;

        NPCAbilities abilities = preset.getAbilities();

        switch (slot) {
            case 11: // Min count
                if (click.isLeftClick()) {
                    abilities.setTntMinCount(abilities.getTntMinCount() + 1);
                } else if (click.isRightClick()) {
                    abilities.setTntMinCount(abilities.getTntMinCount() - 1);
                }
                savePreset(player, preset);
                openTntSettings(player);
                break;

            case 13: // Max count
                if (click.isLeftClick()) {
                    abilities.setTntMaxCount(abilities.getTntMaxCount() + 1);
                } else if (click.isRightClick()) {
                    abilities.setTntMaxCount(abilities.getTntMaxCount() - 1);
                }
                savePreset(player, preset);
                openTntSettings(player);
                break;

            case 15: // Interval
                int change = click.isShiftClick() ? 15 : 5;
                if (click.isLeftClick()) {
                    abilities.setTntInterval(abilities.getTntInterval() + change);
                } else if (click.isRightClick()) {
                    abilities.setTntInterval(abilities.getTntInterval() - change);
                }
                savePreset(player, preset);
                openTntSettings(player);
                break;

            case 31: // Back
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openAbilityMenu(player, presetName), 1L);
                break;
        }
    }

    private void handleLightningMenuClick(Player player, int slot, ClickType click) {
        String presetName = editingPreset.get(player.getUniqueId());
        NPCPreset preset = findPreset(player, presetName);
        if (preset == null) return;

        NPCAbilities abilities = preset.getAbilities();

        switch (slot) {
            case 13: // Interval
                int change = click.isShiftClick() ? 15 : 5;
                if (click.isLeftClick()) {
                    abilities.setLightningInterval(abilities.getLightningInterval() + change);
                } else if (click.isRightClick()) {
                    abilities.setLightningInterval(abilities.getLightningInterval() - change);
                }
                savePreset(player, preset);
                openLightningSettings(player);
                break;

            case 31: // Back
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openAbilityMenu(player, presetName), 1L);
                break;
        }
    }

    private void handleLaunchMenuClick(Player player, int slot, ClickType click) {
        String presetName = editingPreset.get(player.getUniqueId());
        NPCPreset preset = findPreset(player, presetName);
        if (preset == null) return;

        NPCAbilities abilities = preset.getAbilities();

        switch (slot) {
            case 11: // Height
                int heightChange = click.isShiftClick() ? 10 : 5;
                if (click.isLeftClick()) {
                    abilities.setLaunchHeight(abilities.getLaunchHeight() + heightChange);
                } else if (click.isRightClick()) {
                    abilities.setLaunchHeight(abilities.getLaunchHeight() - heightChange);
                }
                savePreset(player, preset);
                openLaunchSettings(player);
                break;

            case 15: // Interval
                int intervalChange = click.isShiftClick() ? 15 : 5;
                if (click.isLeftClick()) {
                    abilities.setLaunchInterval(abilities.getLaunchInterval() + intervalChange);
                } else if (click.isRightClick()) {
                    abilities.setLaunchInterval(abilities.getLaunchInterval() - intervalChange);
                }
                savePreset(player, preset);
                openLaunchSettings(player);
                break;

            case 31: // Back
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openAbilityMenu(player, presetName), 1L);
                break;
        }
    }

    private NPCPreset findPreset(Player player, String presetName) {
        if (presetName == null) return null;

        // Сначала ищем у игрока
        NPCPreset preset = presetManager.getPresetByName(player.getUniqueId(), presetName);
        if (preset != null) return preset;

        // Ищем у всех
        for (UUID playerId : presetManager.getAllPlayerIds()) {
            preset = presetManager.getPresetByName(playerId, presetName);
            if (preset != null) return preset;
        }
        return null;
    }

    private void saveAndRefresh(Player player, String presetName) {
        NPCPreset preset = findPreset(player, presetName);
        if (preset != null) {
            savePreset(player, preset);
            openAbilityMenu(player, presetName);
        }
    }

    private void savePreset(Player player, NPCPreset preset) {
        presetManager.savePreset(player.getUniqueId(), preset);
    }

    private ItemStack createItem(Material material, String name, List<String> lore) {
        ItemStack item = new ItemStack(material);
        ItemMeta meta = item.getItemMeta();
        if (meta != null) {
            meta.setDisplayName(name);
            if (lore != null) meta.setLore(lore);
            item.setItemMeta(meta);
        }
        return item;
    }
}


