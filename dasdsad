package org.exampl.npcplugin_shahed;

import org.exampl.npcplugin_shahed.commands.AirdropCommand;
import org.exampl.npcplugin_shahed.commands.NPCCommand;
import org.exampl.npcplugin_shahed.gui.AbilityGUI;
import org.exampl.npcplugin_shahed.gui.AirdropGUI;
import org.exampl.npcplugin_shahed.gui.AirdropNpcGUI;
import org.exampl.npcplugin_shahed.gui.PresetGUI;
import org.exampl.npcplugin_shahed.manager.AirdropManager;
import org.exampl.npcplugin_shahed.manager.NPCManager;
import org.exampl.npcplugin_shahed.manager.PresetManager;
import org.bukkit.command.PluginCommand;
import org.bukkit.plugin.java.JavaPlugin;
import org.bukkit.Bukkit;
import org.bukkit.command.CommandExecutor;
import org.bukkit.command.TabCompleter;

public class CustomNPC extends JavaPlugin {

    private static CustomNPC instance;
    private NPCManager npcManager;
    private PresetManager presetManager;
    private PresetGUI presetGUI;
    private AbilityGUI abilityGUI;
    private AirdropManager airdropManager;
    private AirdropGUI airdropGUI;
    private AirdropNpcGUI airdropNpcGUI;

    @Override
    public void onEnable() {
        instance = this;

        try {
            if (!getDataFolder().exists()) {
                getDataFolder().mkdirs();
            }

            presetManager = new PresetManager(this);
            npcManager = new NPCManager(this);
            abilityGUI = new AbilityGUI(this, presetManager);
            presetGUI = new PresetGUI(this, presetManager, npcManager, abilityGUI);
            airdropManager = new AirdropManager(this);
            airdropGUI = new AirdropGUI(this, airdropManager);
            airdropNpcGUI = new AirdropNpcGUI(this, airdropManager, presetManager);

            getCommand("npc").setExecutor(new NPCCommand(this, npcManager, presetGUI));

            // Создаём команду и РЕГИСТРИРУЕМ КАК LISTENER!
            AirdropCommand airdropCmd = new AirdropCommand(airdropManager, airdropGUI, airdropNpcGUI);

            // Регистрируем события для GUI
            Bukkit.getPluginManager().registerEvents(airdropCmd, this);

            // Регистрируем команды
            registerCommand("airdrop", airdropCmd);
            registerCommand("airdropspawn", airdropCmd);
            registerCommand("airdropspawnhere", airdropCmd);
            registerCommand("airdropsettime", airdropCmd);
            registerCommand("airdroptime", airdropCmd);
            registerCommand("airdropinfo", airdropCmd);
            registerCommand("airdropsetcenter", airdropCmd);
            registerCommand("airdropchance", airdropCmd);
            registerCommand("airdroploot", airdropCmd);
            registerCommand("airdropsetnpc", airdropCmd);
            registerCommand("airdropguards", airdropCmd);

            getLogger().info("CustomNPC плагин запущен!");

        } catch (Exception e) {
            getLogger().severe("Ошибка при запуске плагина!");
            e.printStackTrace();
            getServer().getPluginManager().disablePlugin(this);
        }
    }

    private void registerCommand(String name, Object executor) {
        if (getCommand(name) != null) {
            getCommand(name).setExecutor((CommandExecutor) executor);
            if (executor instanceof TabCompleter) {
                getCommand(name).setTabCompleter((TabCompleter) executor);
            }
        }
    }

    @Override
    public void onDisable() {
        if (airdropManager != null) {
            airdropManager.shutdown();
        }
        if (npcManager != null) {
            npcManager.removeAllNPCs();
        }
        getLogger().info("CustomNPC плагин выключен!");
    }

    public static CustomNPC getInstance() {
        return instance;
    }

    public PresetManager getPresetManager() {
        return presetManager;
    }

    public NPCManager getNpcManager() {
        return npcManager;
    }

    public AirdropManager getAirdropManager() {
        return airdropManager;
    }

    public AbilityGUI getAbilityGUI() {
        return abilityGUI;
    }
}
