package org.exampl.npcplugin_shahed.manager;

import org.exampl.npcplugin_shahed.CustomNPC;
import org.exampl.npcplugin_shahed.data.NPCAbilities;
import org.exampl.npcplugin_shahed.data.NPCPreset;
import org.bukkit.configuration.file.FileConfiguration;
import org.bukkit.configuration.file.YamlConfiguration;

import java.io.File;
import java.io.IOException;
import java.util.*;

public class PresetManager {

    private final CustomNPC plugin;
    private final Map<UUID, List<NPCPreset>> playerPresets = new HashMap<>();
    private final File presetsFolder;
    private final int MAX_PRESETS = 20;

    public PresetManager(CustomNPC plugin) {
        this.plugin = plugin;
        this.presetsFolder = new File(plugin.getDataFolder(), "presets");
        if (!presetsFolder.exists()) {
            presetsFolder.mkdirs();
        }
        loadAllPresets();
    }

    public List<NPCPreset> getPresets(UUID playerId) {
        return playerPresets.getOrDefault(playerId, new ArrayList<>());
    }

    public boolean savePreset(UUID playerId, NPCPreset preset) {
        List<NPCPreset> presets = playerPresets.computeIfAbsent(playerId, k -> new ArrayList<>());

        // Обновляем существующий или добавляем новый
        boolean found = false;
        for (int i = 0; i < presets.size(); i++) {
            if (presets.get(i).getName().equals(preset.getName())) {
                presets.set(i, preset);
                found = true;
                break;
            }
        }

        if (!found) {
            if (presets.size() >= MAX_PRESETS) {
                return false;
            }
            presets.add(preset);
        }

        savePlayerPresets(playerId);
        return true;
    }

    public boolean deletePreset(UUID playerId, String presetName) {
        List<NPCPreset> presets = playerPresets.get(playerId);
        if (presets != null) {
            boolean removed = presets.removeIf(p -> p.getName().equals(presetName));
            if (removed) {
                savePlayerPresets(playerId);
            }
            return removed;
        }
        return false;
    }

    public NPCPreset getPreset(UUID playerId, String presetName) {
        List<NPCPreset> presets = playerPresets.get(playerId);
        if (presets != null) {
            for (NPCPreset preset : presets) {
                if (preset.getName().equals(presetName)) {
                    return preset;
                }
            }
        }
        return null;
    }

    public NPCPreset getPreset(UUID playerId, int index) {
        List<NPCPreset> presets = playerPresets.get(playerId);
        if (presets != null && index >= 0 && index < presets.size()) {
            return presets.get(index);
        }
        return null;
    }

    public int getPresetCount(UUID playerId) {
        List<NPCPreset> presets = playerPresets.get(playerId);
        return presets != null ? presets.size() : 0;
    }

    public int getMaxPresets() {
        return MAX_PRESETS;
    }

    public Set<UUID> getAllPlayerIds() {
        return playerPresets.keySet();
    }

    public NPCPreset getPresetByName(UUID playerId, String name) {
        List<NPCPreset> presets = playerPresets.get(playerId);
        if (presets != null) {
            for (NPCPreset preset : presets) {
                if (preset.getName().equalsIgnoreCase(name)) {
                    return preset;
                }
            }
        }
        return null;
    }

    private void savePlayerPresets(UUID playerId) {
        File file = new File(presetsFolder, playerId.toString() + ".yml");
        FileConfiguration config = YamlConfiguration.loadConfiguration(file);

        List<NPCPreset> presets = playerPresets.get(playerId);

        config.set("presets", null);

        if (presets != null) {
            for (int i = 0; i < presets.size(); i++) {
                NPCPreset preset = presets.get(i);
                String path = "presets." + i;

                config.set(path + ".name", preset.getName());
                config.set(path + ".displayName", preset.getDisplayName());
                config.set(path + ".mobType", preset.getMobType());
                config.set(path + ".health", preset.getHealth());
                config.set(path + ".speed", preset.getSpeed());
                config.set(path + ".aggroMode", preset.getAggroMode());
                config.set(path + ".weapon", preset.getWeapon());
                config.set(path + ".offHand", preset.getOffHand());
                config.set(path + ".helmet", preset.getHelmet());
                config.set(path + ".chestplate", preset.getChestplate());
                config.set(path + ".leggings", preset.getLeggings());
                config.set(path + ".boots", preset.getBoots());

                // Сохраняем способности
                NPCAbilities abilities = preset.getAbilities();
                String abPath = path + ".abilities";
                config.set(abPath + ".tntEnabled", abilities.isTntEnabled());
                config.set(abPath + ".tntMinCount", abilities.getTntMinCount());
                config.set(abPath + ".tntMaxCount", abilities.getTntMaxCount());
                config.set(abPath + ".tntInterval", abilities.getTntInterval());
                config.set(abPath + ".lightningEnabled", abilities.isLightningEnabled());
                config.set(abPath + ".lightningInterval", abilities.getLightningInterval());
                config.set(abPath + ".launchEnabled", abilities.isLaunchEnabled());
                config.set(abPath + ".launchHeight", abilities.getLaunchHeight());
                config.set(abPath + ".launchInterval", abilities.getLaunchInterval());
                config.set(abPath + ".activationRadius", abilities.getActivationRadius());
            }
        }

        try {
            config.save(file);
        } catch (IOException e) {
            plugin.getLogger().severe("Не удалось сохранить пресеты для " + playerId);
            e.printStackTrace();
        }
    }

    private void loadAllPresets() {
        File[] files = presetsFolder.listFiles((dir, name) -> name.endsWith(".yml"));
        if (files == null) return;

        for (File file : files) {
            String fileName = file.getName().replace(".yml", "");
            try {
                UUID playerId = UUID.fromString(fileName);
                loadPlayerPresets(playerId, file);
            } catch (IllegalArgumentException e) {
                plugin.getLogger().warning("Неверный файл пресетов: " + fileName);
            }
        }
    }

    private void loadPlayerPresets(UUID playerId, File file) {
        FileConfiguration config = YamlConfiguration.loadConfiguration(file);
        List<NPCPreset> presets = new ArrayList<>();

        if (config.contains("presets")) {
            for (String key : config.getConfigurationSection("presets").getKeys(false)) {
                String path = "presets." + key;

                String name = config.getString(path + ".name", "Preset");
                NPCPreset preset = new NPCPreset(name);

                preset.setDisplayName(config.getString(path + ".displayName", "NPC"));
                preset.setMobType(config.getString(path + ".mobType", "zombie"));
                preset.setHealth(config.getDouble(path + ".health", 20.0));
                preset.setSpeed(config.getDouble(path + ".speed", 0.23));
                preset.setAggroMode(config.getString(path + ".aggroMode", "all"));
                preset.setWeapon(config.getItemStack(path + ".weapon"));
                preset.setOffHand(config.getItemStack(path + ".offHand"));
                preset.setHelmet(config.getItemStack(path + ".helmet"));
                preset.setChestplate(config.getItemStack(path + ".chestplate"));
                preset.setLeggings(config.getItemStack(path + ".leggings"));
                preset.setBoots(config.getItemStack(path + ".boots"));

                // Загружаем способности
                String abPath = path + ".abilities";
                if (config.contains(abPath)) {
                    NPCAbilities abilities = preset.getAbilities();
                    abilities.setTntEnabled(config.getBoolean(abPath + ".tntEnabled", false));
                    abilities.setTntMinCount(config.getInt(abPath + ".tntMinCount", 2));
                    abilities.setTntMaxCount(config.getInt(abPath + ".tntMaxCount", 4));
                    abilities.setTntInterval(config.getInt(abPath + ".tntInterval", 15));
                    abilities.setLightningEnabled(config.getBoolean(abPath + ".lightningEnabled", false));
                    abilities.setLightningInterval(config.getInt(abPath + ".lightningInterval", 50));
                    abilities.setLaunchEnabled(config.getBoolean(abPath + ".launchEnabled", false));
                    abilities.setLaunchHeight(config.getInt(abPath + ".launchHeight", 30));
                    abilities.setLaunchInterval(config.getInt(abPath + ".launchInterval", 60));
                    abilities.setActivationRadius(config.getInt(abPath + ".activationRadius", 32));
                }

                presets.add(preset);
            }
        }

        playerPresets.put(playerId, presets);
    }
}


