        for (int i = 45; i < 54; i++) {
            if (inv.getItem(i) == null) inv.setItem(i, filler);
        }

        player.openInventory(inv);
    }

    @EventHandler
    public void onInventoryClick(InventoryClickEvent event) {
        if (!(event.getWhoClicked() instanceof Player)) return;
        Player player = (Player) event.getWhoClicked();
        String title = event.getView().getTitle();

        if (title.equals(TYPE_MENU)) {
            event.setCancelled(true);

            String type = null;
            switch (event.getSlot()) {
                case 11: type = "common"; break;
                case 13: type = "rare"; break;
                case 15: type = "legendary"; break;
            }

            if (type != null) {
                player.closeInventory();
                String finalType = type;
                Bukkit.getScheduler().runTaskLater(plugin, () -> openPresetMenu(player, finalType), 1L);
            }
        } else if (title.equals(PRESET_MENU)) {
            event.setCancelled(true);

            int slot = event.getSlot();
            String airdropType = selectingForType.get(player.getUniqueId());

            if (slot == 45) { // Назад
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openTypeMenu(player), 1L);
            } else if (slot == 49) { // Убрать
                if (airdropType != null) {
                    airdropManager.setNpcPreset(airdropType, null);
                    player.sendMessage("§cПресет для §e" + airdropType + " §cубран!");
                }
                player.closeInventory();
            } else if (slot < 45) {
                ItemStack item = event.getCurrentItem();
                if (item != null && item.hasItemMeta() && item.getItemMeta().hasDisplayName()) {
                    String presetName = item.getItemMeta().getDisplayName().substring(2); // Убираем §e

                    if (airdropType != null) {
                        airdropManager.setNpcPreset(airdropType, presetName);
                        player.sendMessage("§aПресет §e" + presetName + " §aустановлен для §e" + airdropType + "§a!");
                    }
                    player.closeInventory();
                }
            }
        }
    }

    private ItemStack createItem(Material material, String name, List<String> lore) {
        ItemStack item = new ItemStack(material);
        ItemMeta meta = item.getItemMeta();
        if (meta != null) {
            meta.setDisplayName(name);
            if (lore != null) meta.setLore(lore);
            item.setItemMeta(meta);
        }
        return item;
    }
}


