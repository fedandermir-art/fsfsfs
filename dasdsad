AirdropCommand:

package org.exampl.npcplugin_shahed.commands;

import org.exampl.npcplugin_shahed.data.AirdropLoot;
import org.exampl.npcplugin_shahed.gui.AirdropGUI;
import org.exampl.npcplugin_shahed.gui.AirdropNpcGUI;
import org.exampl.npcplugin_shahed.manager.AirdropManager;
import org.bukkit.Bukkit;
import org.bukkit.Material;
import org.bukkit.command.Command;
import org.bukkit.command.CommandExecutor;
import org.bukkit.command.CommandSender;
import org.bukkit.command.TabCompleter;
import org.bukkit.entity.Player;
import org.bukkit.event.EventHandler;
import org.bukkit.event.EventPriority;
import org.bukkit.event.Listener;
import org.bukkit.event.inventory.InventoryClickEvent;
import org.bukkit.event.inventory.InventoryCloseEvent;
import org.bukkit.inventory.Inventory;
import org.bukkit.inventory.ItemStack;
import org.bukkit.inventory.meta.ItemMeta;

import java.util.*;

public class AirdropCommand implements CommandExecutor, TabCompleter, Listener {

    private final AirdropManager airdropManager;
    private final AirdropGUI airdropGUI;
    private final AirdropNpcGUI airdropNpcGUI;

    private final Map<UUID, String> editingLoot = new HashMap<>();

    private static final String LOOT_SELECT_TITLE = "§6§lВыберите тип лута";
    private static final String LOOT_EDIT_PREFIX = "§6§lЛут: ";

    public AirdropCommand(AirdropManager airdropManager, AirdropGUI airdropGUI, AirdropNpcGUI airdropNpcGUI) {
        this.airdropManager = airdropManager;
        this.airdropGUI = airdropGUI;
        this.airdropNpcGUI = airdropNpcGUI;
    }

    @Override
    public boolean onCommand(CommandSender sender, Command command, String label, String[] args) {
        if (!(sender instanceof Player)) {
            sender.sendMessage("§cТолько для игроков!");
            return true;
        }

        Player player = (Player) sender;
        String cmdName = command.getName().toLowerCase();

        switch (cmdName) {
            case "airdrop":
                return handleMainCommand(player, args);
            case "airdropspawn":
                return handleSpawn(player);
            case "airdropspawnhere":
                return handleSpawnHere(player);
            case "airdropsettime":
                return handleSetTime(player, args);
            case "airdroptime":
                return handleTime(player);
            case "airdropinfo":
                return handleInfo(player);
            case "airdropsetcenter":
                return handleSetCenter(player);
            case "airdropchance":
                return handleChance(player, args);
            case "airdroploot":
                return handleLoot(player, args);
            case "airdropsetnpc":
                return handleSetNpc(player, args);
            case "airdropguards":
                return handleGuards(player, args);
            default:
                sendHelp(player);
                return true;
        }
    }

    private boolean handleMainCommand(Player player, String[] args) {
        if (args.length == 0) {
            sendHelp(player);
            return true;
        }

        String sub = args[0].toLowerCase();
        String[] subArgs = args.length > 1 ? Arrays.copyOfRange(args, 1, args.length) : new String[0];

        switch (sub) {
            case "spawn":
            case "force":
                return handleSpawn(player);
            case "here":
                return handleSpawnHere(player);
            case "setcenter":
                return handleSetCenter(player);
            case "settime":
            case "setinterval":
                return handleSetTime(player, subArgs);
            case "time":
                return handleTime(player);
            case "info":
            case "status":
                return handleInfo(player);
            case "remove":
            case "delete":
            case "stop":
                return handleRemove(player);
            case "tp":
            case "teleport":
                return handleTeleport(player);
            case "guards":
                return handleGuards(player, subArgs);
            case "chance":
                return handleChance(player, subArgs);
            case "setnpc":
                return handleSetNpc(player, subArgs);
            case "loot":
                return handleLoot(player, subArgs);
            default:
                sendHelp(player);
                return true;
        }
    }

    private boolean handleSpawn(Player player) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        airdropManager.forceSpawn(player);
        player.sendMessage("§a§l✔ Аирдроп заспавнен!");
        return true;
    }

    private boolean handleSpawnHere(Player player) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        airdropManager.spawnHere(player);
        player.sendMessage("§a§l✔ Аирдроп заспавнен здесь!");
        return true;
    }

    private boolean handleSetTime(Player player, String[] args) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        if (args.length < 1) {
            player.sendMessage("§7Текущий интервал: §f" + airdropManager.getInterval() + " мин");
            player.sendMessage("§7Использование: §f/airdropsettime <минуты>");
            return true;
        }
        try {
            int minutes = Integer.parseInt(args[0]);
            if (minutes < 1 || minutes > 1440) {
                player.sendMessage("§c§l✘ От 1 до 1440 минут!");
                return true;
            }
            airdropManager.setInterval(minutes);
            player.sendMessage("§a§l✔ Интервал: §f" + minutes + " мин");
        } catch (NumberFormatException e) {
            player.sendMessage("§c§l✘ Введите число!");
        }
        return true;
    }

    private boolean handleTime(Player player) {
        player.sendMessage("§6До аирдропа: " + airdropManager.getFormattedTime());
        return true;
    }

    private boolean handleInfo(Player player) {
        player.sendMessage("");
        player.sendMessage("§6§l▬▬▬▬▬▬▬▬ АИРДРОП ▬▬▬▬▬▬▬▬");
        if (airdropManager.isAirdropActive()) {
            player.sendMessage("§7Статус: §a§lАКТИВЕН");
            player.sendMessage("§7Тип: §f" + airdropManager.getCurrentLootType());
            player.sendMessage("§7Охранников: §c" + airdropManager.getAliveGuardsCount());
            if (airdropManager.getCurrentLocation() != null) {
                player.sendMessage("§7Координаты: §eX:" + airdropManager.getCurrentLocation().getBlockX() +
                        " Y:" + airdropManager.getCurrentLocation().getBlockY() +
                        " Z:" + airdropManager.getCurrentLocation().getBlockZ());
            }
        } else {
            player.sendMessage("§7Статус: §c§lНЕАКТИВЕН");
            player.sendMessage("§7До спавна: " + airdropManager.getFormattedTime());
        }
        player.sendMessage("§7Интервал: §f" + airdropManager.getInterval() + " мин");
        player.sendMessage("§6§l▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬");
        return true;
    }

    private boolean handleSetCenter(Player player) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        airdropManager.setCenter(player.getWorld(), player.getLocation().getBlockX(), player.getLocation().getBlockZ());
        player.sendMessage("§a§l✔ Центр установлен!");
        player.sendMessage("§7Мир: §f" + player.getWorld().getName());
        player.sendMessage("§7X: §f" + player.getLocation().getBlockX() + " §7Z: §f" + player.getLocation().getBlockZ());
        return true;
    }

    private boolean handleChance(Player player, String[] args) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        if (args.length < 2) {
            AirdropLoot c = airdropManager.getLoot("common");
            AirdropLoot r = airdropManager.getLoot("rare");
            AirdropLoot l = airdropManager.getLoot("legendary");
            player.sendMessage("§7Common: §f" + (c != null ? c.getChance() : 60) + "%");
            player.sendMessage("§9Rare: §f" + (r != null ? r.getChance() : 30) + "%");
            player.sendMessage("§6Legendary: §f" + (l != null ? l.getChance() : 10) + "%");
            player.sendMessage("§7Использование: §f/airdropchance <тип> <шанс>");
            return true;
        }
        String type = args[0].toLowerCase();
        if (!type.equals("common") && !type.equals("rare") && !type.equals("legendary")) {
            player.sendMessage("§c§l✘ Типы: common, rare, legendary");
            return true;
        }
        try {
            int chance = Integer.parseInt(args[1]);
            if (chance < 0 || chance > 100) {
                player.sendMessage("§c§l✘ От 0 до 100!");
                return true;
            }
            airdropManager.setLootChance(type, chance);
            player.sendMessage("§a§l✔ Шанс §f" + type + "§a: §f" + chance + "%");
        } catch (NumberFormatException e) {
            player.sendMessage("§c§l✘ Введите число!");
        }
        return true;
    }

    // ========================================
    // /airdroploot - ОТКРЫВАЕТ GUI
    // ========================================

    private boolean handleLoot(Player player, String[] args) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }

        if (args.length >= 1) {
            String type = args[0].toLowerCase();
            if (type.equals("common") || type.equals("rare") || type.equals("legendary")) {
                openLootEditor(player, type);
                return true;
            }
        }

        openLootSelector(player);
        return true;
    }

    private void openLootSelector(Player player) {
        Inventory inv = Bukkit.createInventory(null, 27, LOOT_SELECT_TITLE);

        // Common
        ItemStack common = new ItemStack(Material.WHITE_SHULKER_BOX);
        ItemMeta cm = common.getItemMeta();
        cm.setDisplayName("§f§lCOMMON");
        AirdropLoot cl = airdropManager.getLoot("common");
        cm.setLore(Arrays.asList("", "§7Шанс: §f" + (cl != null ? cl.getChance() : 60) + "%",
                "§7Предметов: §f" + (cl != null ? cl.getItems().size() : 0), "", "§eНажми для редактирования"));
        common.setItemMeta(cm);
        inv.setItem(11, common);

        // Rare
        ItemStack rare = new ItemStack(Material.BLUE_SHULKER_BOX);
        ItemMeta rm = rare.getItemMeta();
        rm.setDisplayName("§9§lRARE");
        AirdropLoot rl = airdropManager.getLoot("rare");
        rm.setLore(Arrays.asList("", "§7Шанс: §f" + (rl != null ? rl.getChance() : 30) + "%",
                "§7Предметов: §f" + (rl != null ? rl.getItems().size() : 0), "", "§eНажми для редактирования"));
        rare.setItemMeta(rm);
        inv.setItem(13, rare);

        // Legendary
        ItemStack legendary = new ItemStack(Material.ORANGE_SHULKER_BOX);
        ItemMeta lm = legendary.getItemMeta();
        lm.setDisplayName("§6§lLEGENDARY");
        AirdropLoot ll = airdropManager.getLoot("legendary");
        lm.setLore(Arrays.asList("", "§7Шанс: §f" + (ll != null ? ll.getChance() : 10) + "%",
                "§7Предметов: §f" + (ll != null ? ll.getItems().size() : 0), "", "§eНажми для редактирования"));
        legendary.setItemMeta(lm);
        inv.setItem(15, legendary);

        // Стекло
        ItemStack glass = new ItemStack(Material.GRAY_STAINED_GLASS_PANE);
        ItemMeta gm = glass.getItemMeta();
        gm.setDisplayName(" ");
        glass.setItemMeta(gm);
        for (int i = 0; i < 27; i++) {
            if (inv.getItem(i) == null) inv.setItem(i, glass);
        }

        player.openInventory(inv);
    }

    private void openLootEditor(Player player, String type) {
        String color;
        String name;
        switch (type) {
            case "rare":
                color = "§9";
                name = "RARE";
                break;
            case "legendary":
                color = "§6";
                name = "LEGENDARY";
                break;
            default:
                color = "§f";
                name = "COMMON";
                break;
        }

        Inventory inv = Bukkit.createInventory(null, 54, LOOT_EDIT_PREFIX + color + name);

        AirdropLoot loot = airdropManager.getLoot(type);
        if (loot != null && loot.getItems() != null) {
            int slot = 0;
            for (ItemStack item : loot.getItems()) {
                if (slot >= 45) break;
                if (item != null && item.getType() != Material.AIR) {
                    inv.setItem(slot++, item.clone());
                }
            }
        }

        // Инфо кнопка
        ItemStack info = new ItemStack(Material.PAPER);
        ItemMeta im = info.getItemMeta();
        im.setDisplayName("§e§lИнфо");
        im.setLore(Arrays.asList("", "§7Положи предметы сюда", "§7При закрытии сохранится", "", "§aСлоты 1-45 для лута"));
        info.setItemMeta(im);
        inv.setItem(49, info);

        // Стекло снизу
        ItemStack glass = new ItemStack(Material.BLACK_STAINED_GLASS_PANE);
        ItemMeta gm = glass.getItemMeta();
        gm.setDisplayName(" ");
        glass.setItemMeta(gm);
        for (int i = 45; i < 54; i++) {
            if (inv.getItem(i) == null) inv.setItem(i, glass);
        }

        editingLoot.put(player.getUniqueId(), type);
        player.openInventory(inv);
        player.sendMessage(color + "§lРедактирование лута: " + name);
    }

    // ========================================
    // ОБРАБОТКА КЛИКОВ
    // ========================================

    @EventHandler(priority = EventPriority.HIGH)
    public void onInventoryClick(InventoryClickEvent event) {
        if (!(event.getWhoClicked() instanceof Player)) return;
        Player player = (Player) event.getWhoClicked();
        String title = event.getView().getTitle();

        // Меню выбора типа
        if (title.equals(LOOT_SELECT_TITLE)) {
            event.setCancelled(true);

            ItemStack clicked = event.getCurrentItem();
            if (clicked == null || clicked.getType() == Material.AIR) return;
            if (clicked.getType() == Material.GRAY_STAINED_GLASS_PANE) return;

            String type = null;
            if (clicked.getType() == Material.WHITE_SHULKER_BOX) type = "common";
            else if (clicked.getType() == Material.BLUE_SHULKER_BOX) type = "rare";
            else if (clicked.getType() == Material.ORANGE_SHULKER_BOX) type = "legendary";

            if (type != null) {
                final String finalType = type;
                // Закрываем и открываем редактор
                Bukkit.getScheduler().runTaskLater(
                        Bukkit.getPluginManager().getPlugin("CustomNPC"),
                        () -> openLootEditor(player, finalType),
                        1L
                );
            }
            return;
        }

        // Редактор лута - блокируем нижний ряд
        if (title.startsWith(LOOT_EDIT_PREFIX)) {
            int slot = event.getRawSlot();
            if (slot >= 45 && slot <= 53) {
                event.setCancelled(true);
            }
        }
    }

    // ========================================
    // СОХРАНЕНИЕ ПРИ ЗАКРЫТИИ
    // ========================================

    @EventHandler
    public void onInventoryClose(InventoryCloseEvent event) {
        if (!(event.getPlayer() instanceof Player)) return;
        Player player = (Player) event.getPlayer();
        String title = event.getView().getTitle();

        if (!title.startsWith(LOOT_EDIT_PREFIX)) return;

        String type = editingLoot.remove(player.getUniqueId());
        if (type == null) return;

        Inventory inv = event.getInventory();
        List<ItemStack> items = new ArrayList<>();

        for (int i = 0; i < 45; i++) {
            ItemStack item = inv.getItem(i);
            if (item != null && item.getType() != Material.AIR) {
                items.add(item.clone());
            }
        }

        AirdropLoot loot = airdropManager.getLoot(type);
        if (loot != null) {
            loot.clearItems();
            for (ItemStack item : items) {
                loot.addItem(item);
            }
            airdropManager.saveLootConfig();

            String color;
            switch (type) {
                case "rare": color = "§9"; break;
                case "legendary": color = "§6"; break;
                default: color = "§f"; break;
            }
            player.sendMessage(color + "§l✔ Лут " + type.toUpperCase() + " сохранён! §7(" + items.size() + " предметов)");
        }
    }

    private boolean handleSetNpc(Player player, String[] args) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        if (args.length < 2) {
            Map<String, String> presets = airdropManager.getAllNpcPresets();
            player.sendMessage("§7Common: §f" + presets.getOrDefault("common", "нет"));
            player.sendMessage("§9Rare: §f" + presets.getOrDefault("rare", "нет"));
            player.sendMessage("§6Legendary: §f" + presets.getOrDefault("legendary", "нет"));
            player.sendMessage("§7Использование: §f/airdropsetnpc <тип> <пресет>");
            return true;
        }
        String type = args[0].toLowerCase();
        if (!type.equals("common") && !type.equals("rare") && !type.equals("legendary")) {
            player.sendMessage("§c§l✘ Типы: common, rare, legendary");
            return true;
        }
        airdropManager.setNpcPreset(type, args[1]);
        player.sendMessage("§a§l✔ NPC для §f" + type + "§a: §f" + args[1]);
        return true;
    }

    private boolean handleGuards(Player player, String[] args) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        if (args.length < 2) {
            player.sendMessage("§7Common: §f" + airdropManager.getGuardCount("common"));
            player.sendMessage("§9Rare: §f" + airdropManager.getGuardCount("rare"));
            player.sendMessage("§6Legendary: §f" + airdropManager.getGuardCount("legendary"));
            player.sendMessage("§7Использование: §f/airdropguards <тип> <количество>");
            return true;
        }
        String type = args[0].toLowerCase();
        if (!type.equals("common") && !type.equals("rare") && !type.equals("legendary")) {
            player.sendMessage("§c§l✘ Типы: common, rare, legendary");
            return true;
        }
        try {
            int count = Integer.parseInt(args[1]);
            if (count < 0 || count > 10) {
                player.sendMessage("§c§l✘ От 0 до 10!");
                return true;
            }
            airdropManager.setGuardCount(type, count);
            player.sendMessage("§a§l✔ Охранники §f" + type + "§a: §f" + count);
        } catch (NumberFormatException e) {
            player.sendMessage("§c§l✘ Введите число!");
        }
        return true;
    }

    private boolean handleRemove(Player player) {
        if (!player.hasPermission("airdrop.admin")) {
            player.sendMessage("§c§l✘ Нет прав!");
            return true;
        }
        if (!airdropManager.isAirdropActive()) {
            player.sendMessage("§c§l✘ Аирдроп не активен!");
            return true;
        }
        airdropManager.removeAirdrop();
        player.sendMessage("§a§l✔ Аирдроп удалён!");
        return true;
    }

    private boolean handleTeleport(Player player) {
        if (!airdropManager.isAirdropActive() || airdropManager.getCurrentLocation() == null) {
            player.sendMessage("§c§l✘ Аирдроп не активен!");
            return true;
        }
        player.teleport(airdropManager.getCurrentLocation().clone().add(0, 2, 0));
        player.sendMessage("§a§l✔ Телепортирован!");
        return true;
    }

    private void sendHelp(Player player) {
        player.sendMessage("");
        player.sendMessage("§6§l▬▬▬▬▬▬▬▬ АИРДРОП ▬▬▬▬▬▬▬▬");
        player.sendMessage("§e/airdrop spawn §7- Заспавнить");
        player.sendMessage("§e/airdrop here §7- Спавн здесь");
        player.sendMessage("§e/airdrop tp §7- Телепорт");
        player.sendMessage("§e/airdrop remove §7- Удалить");
        player.sendMessage("§e/airdrop info §7- Инфо");
        player.sendMessage("§e/airdrop setcenter §7- Центр");
        player.sendMessage("§e/airdrop settime <мин> §7- Интервал");
        player.sendMessage("§e/airdrop guards <тип> <кол> §7- Охранники");
        player.sendMessage("§e/airdrop chance <тип> <%> §7- Шанс");
        player.sendMessage("§e/airdrop setnpc <тип> <пресет> §7- NPC");
        player.sendMessage("§e/airdrop loot §7- §a§lРедактор лута");
        player.sendMessage("§6§l▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬");
    }

    @Override
    public List<String> onTabComplete(CommandSender sender, Command command, String alias, String[] args) {
        List<String> list = new ArrayList<>();
        String cmd = command.getName().toLowerCase();

        if (cmd.equals("airdrop") && args.length == 1) {
            for (String s : Arrays.asList("spawn", "here", "tp", "remove", "info", "setcenter", "settime", "guards", "chance", "setnpc", "loot")) {
                if (s.startsWith(args[0].toLowerCase())) list.add(s);
            }
        } else if (cmd.equals("airdrop") && args.length == 2) {
            if (args[0].equalsIgnoreCase("guards") || args[0].equalsIgnoreCase("chance") ||
                    args[0].equalsIgnoreCase("setnpc") || args[0].equalsIgnoreCase("loot")) {
                for (String s : Arrays.asList("common", "rare", "legendary")) {
                    if (s.startsWith(args[1].toLowerCase())) list.add(s);
                }
            }
        }
        return list;
    }
}


