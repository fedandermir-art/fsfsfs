    @EventHandler
    public void onInventoryClick(InventoryClickEvent event) {
        if (!(event.getWhoClicked() instanceof Player)) return;
        Player player = (Player) event.getWhoClicked();
        String title = event.getView().getTitle();

        if (title.equals(MAIN_MENU_TITLE)) {
            event.setCancelled(true);
            handleMainMenuClick(player, event.getSlot());
        } else if (title.equals(SAVE_MENU_TITLE)) {
            event.setCancelled(true);
            handleSaveMenuClick(player, event.getSlot());
        } else if (title.equals(LOAD_MENU_TITLE)) {
            event.setCancelled(true);
            handleLoadMenuClick(player, event.getSlot());
        } else if (title.equals(DELETE_MENU_TITLE)) {
            event.setCancelled(true);
            handleDeleteMenuClick(player, event.getSlot());
        } else if (title.equals(ABILITY_SELECT_TITLE)) {
            event.setCancelled(true);
            handleAbilitySelectClick(player, event.getSlot());
        }
    }

    @EventHandler
    public void onInventoryClose(InventoryCloseEvent event) {
        if (!(event.getPlayer() instanceof Player)) return;
        Player player = (Player) event.getPlayer();
        UUID playerId = player.getUniqueId();

        playersInSaveMode.remove(playerId);
        playersInLoadMode.remove(playerId);
        playersInDeleteMode.remove(playerId);
        playersInAbilitySelectMode.remove(playerId);
    }

    private void handleMainMenuClick(Player player, int slot) {
        switch (slot) {
            case 11:
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openSaveMenu(player), 1L);
                break;
            case 13:
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openLoadMenu(player), 1L);
                break;
            case 15:
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openDeleteMenu(player), 1L);
                break;
            case 22: // Способности
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openAbilitySelectMenu(player), 1L);
                break;
        }
    }

    private void handleAbilitySelectClick(Player player, int slot) {
        if (slot == 31) {
            player.closeInventory();
            Bukkit.getScheduler().runTaskLater(plugin, () -> openMainMenu(player), 1L);
            return;
        }

        if (slot >= 0 && slot < 20) {
            NPCPreset preset = presetManager.getPreset(player.getUniqueId(), slot);
            if (preset != null) {
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () ->
                        abilityGUI.openAbilityMenu(player, preset.getName()), 1L);
            }
        }
    }

    private void handleSaveMenuClick(Player player, int slot) {
        if (slot == 31) {
            player.closeInventory();
            Bukkit.getScheduler().runTaskLater(plugin, () -> openMainMenu(player), 1L);
            return;
        }

        if (slot >= 0 && slot < 20) {
            LivingEntity npc = npcManager.getNearestNPC(player);
            if (npc == null) {
                player.sendMessage("§cРядом нет NPC для сохранения!");
                player.closeInventory();
                return;
            }

            String presetName = "Пресет_" + (slot + 1);
            NPCPreset existingPreset = presetManager.getPreset(player.getUniqueId(), slot);
            if (existingPreset != null) {
                presetName = existingPreset.getName();
            }

            NPCPreset preset = createPresetFromNPC(npc, presetName);

            if (presetManager.savePreset(player.getUniqueId(), preset)) {
                player.sendMessage("§aПресет §e" + presetName + " §aсохранен!");
            } else {
                player.sendMessage("§cДостигнут лимит пресетов (20)!");
            }

            player.closeInventory();
        }
    }

    private void handleLoadMenuClick(Player player, int slot) {
        if (slot == 31) {
            player.closeInventory();
            Bukkit.getScheduler().runTaskLater(plugin, () -> openMainMenu(player), 1L);
            return;
        }

        if (slot >= 0 && slot < 20) {
            NPCPreset preset = presetManager.getPreset(player.getUniqueId(), slot);
            if (preset == null) {
                return;
            }

            LivingEntity npc = npcManager.getNearestNPC(player);
            if (npc == null) {
                player.sendMessage("§cРядом нет NPC!");
                player.closeInventory();
                return;
            }

            applyPresetToNPC(npc, preset);
            player.sendMessage("§aПресет §e" + preset.getName() + " §aприменен к NPC!");
            player.closeInventory();
        }
    }

    private void handleDeleteMenuClick(Player player, int slot) {
        if (slot == 31) {
            player.closeInventory();
            Bukkit.getScheduler().runTaskLater(plugin, () -> openMainMenu(player), 1L);
            return;
        }

        if (slot >= 0 && slot < 20) {
            NPCPreset preset = presetManager.getPreset(player.getUniqueId(), slot);
            if (preset == null) {
                return;
            }

            if (presetManager.deletePreset(player.getUniqueId(), preset.getName())) {
                player.sendMessage("§cПресет §e" + preset.getName() + " §cудален!");
            }

            player.closeInventory();
            Bukkit.getScheduler().runTaskLater(plugin, () -> openDeleteMenu(player), 1L);
        }
    }

    private NPCPreset createPresetFromNPC(LivingEntity npc, String name) {
        NPCPreset preset = new NPCPreset(name);

        preset.setDisplayName(npc.getCustomName() != null ? npc.getCustomName() : "NPC");
        preset.setHealth(npc.getHealth());

        if (npc.getAttribute(Attribute.MOVEMENT_SPEED) != null) {
            preset.setSpeed(npc.getAttribute(Attribute.MOVEMENT_SPEED).getBaseValue());
        }

        if (npc.getEquipment() != null) {
            preset.setWeapon(npc.getEquipment().getItemInMainHand());
            preset.setOffHand(npc.getEquipment().getItemInOffHand());
            preset.setHelmet(npc.getEquipment().getHelmet());
            preset.setChestplate(npc.getEquipment().getChestplate());
            preset.setLeggings(npc.getEquipment().getLeggings());
            preset.setBoots(npc.getEquipment().getBoots());
        }

        return preset;
    }

    private void applyPresetToNPC(LivingEntity npc, NPCPreset preset) {
        UUID npcId = npc.getUniqueId();

        npcManager.setNPCName(npcId, preset.getDisplayName());
        npcManager.setNPCHealth(npcId, preset.getHealth());
        npcManager.setNPCSpeed(npcId, preset.getSpeed());

        if (preset.getWeapon() != null) {
            npcManager.setNPCWeapon(npcId, preset.getWeapon());
        }
        if (preset.getOffHand() != null) {
            npcManager.setNPCOffHand(npcId, preset.getOffHand());
        }

        npcManager.setNPCArmor(npcId,
                preset.getHelmet(),
                preset.getChestplate(),
                preset.getLeggings(),
                preset.getBoots());

        if (preset.getAggroMode() != null) {
            npcManager.setAggroMode(npcId, preset.getAggroMode());
        }
    }

    private ItemStack createItem(Material material, String name, List<String> lore) {
        ItemStack item = new ItemStack(material);
        ItemMeta meta = item.getItemMeta();
        if (meta != null) {
            meta.setDisplayName(name);
            if (lore != null) {
                meta.setLore(lore);
            }
            item.setItemMeta(meta);
        }
        return item;
    }
}


