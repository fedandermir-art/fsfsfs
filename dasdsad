package org.exampl.npcplugin_shahed.manager;

import org.exampl.npcplugin_shahed.CustomNPC;
import org.bukkit.Bukkit;
import org.bukkit.Location;
import org.bukkit.attribute.Attribute;
import org.bukkit.boss.BarColor;
import org.bukkit.boss.BarStyle;
import org.bukkit.boss.BossBar;
import org.bukkit.entity.*;
import org.bukkit.event.EventHandler;
import org.bukkit.event.Listener;
import org.bukkit.event.entity.EntityDamageEvent;
import org.bukkit.event.entity.EntityDeathEvent;
import org.bukkit.inventory.ItemStack;
import org.bukkit.scheduler.BukkitRunnable;

import java.util.HashMap;
import java.util.Iterator;
import java.util.Map;
import java.util.UUID;

public class NPCManager implements Listener {

    private final CustomNPC plugin;
    private final Map<UUID, LivingEntity> npcs = new HashMap<>();
    private final Map<UUID, String> npcAggroMode = new HashMap<>();
    private final Map<UUID, BossBar> npcBossBars = new HashMap<>();

    public NPCManager(CustomNPC plugin) {
        this.plugin = plugin;
        Bukkit.getPluginManager().registerEvents(this, plugin);
        startAggroTask();
        startBossBarTask();
    }

    public LivingEntity spawnNPC(Location location, String mobType) {
        LivingEntity entity;

        switch (mobType.toLowerCase()) {
            case "skeleton":
                Skeleton skeleton = location.getWorld().spawn(location, Skeleton.class);
                skeleton.setShouldBurnInDay(false);
                skeleton.getEquipment().setItemInMainHand(null);
                entity = skeleton;
                break;
            case "wither_skeleton":
            case "witherskeleton":
            case "wither":
                WitherSkeleton witherSkeleton = location.getWorld().spawn(location, WitherSkeleton.class);
                witherSkeleton.getEquipment().setItemInMainHand(null);
                entity = witherSkeleton;
                break;
            case "zombie":
            default:
                Zombie zombie = location.getWorld().spawn(location, Zombie.class);
                zombie.setShouldBurnInDay(false);
                zombie.setAdult();
                entity = zombie;
                break;
        }

        entity.setCustomName("NPC");
        entity.setCustomNameVisible(true);
        entity.setRemoveWhenFarAway(false);
        entity.setPersistent(true);

        BossBar bossBar = Bukkit.createBossBar(
                "§c§lNPC",
                BarColor.RED,
                BarStyle.SOLID
        );
        bossBar.setProgress(1.0);

        npcs.put(entity.getUniqueId(), entity);
        npcAggroMode.put(entity.getUniqueId(), "all");
        npcBossBars.put(entity.getUniqueId(), bossBar);

        return entity;
    }

    public boolean removeNPC(UUID npcId) {
        LivingEntity npc = npcs.remove(npcId);
        if (npc != null) {
            npcAggroMode.remove(npcId);

            BossBar bossBar = npcBossBars.remove(npcId);
            if (bossBar != null) {
                bossBar.removeAll();
            }

            npc.remove();
            return true;
        }
        return false;
    }

    public void removeAllNPCs() {
        for (LivingEntity npc : npcs.values()) {
            npc.remove();
        }
        for (BossBar bossBar : npcBossBars.values()) {
            bossBar.removeAll();
        }
        npcs.clear();
        npcAggroMode.clear();
        npcBossBars.clear();
    }

    public LivingEntity getNPC(UUID npcId) {
        return npcs.get(npcId);
    }

    public LivingEntity getNearestNPC(Player player) {
        LivingEntity nearest = null;
        double minDistance = Double.MAX_VALUE;

        for (LivingEntity npc : npcs.values()) {
            if (npc.getWorld().equals(player.getWorld())) {
                double distance = npc.getLocation().distance(player.getLocation());
                if (distance < minDistance) {
                    minDistance = distance;
                    nearest = npc;
                }
            }
        }

        return nearest;
    }

    public void setNPCName(UUID npcId, String name) {
        LivingEntity npc = npcs.get(npcId);
        if (npc != null) {
            String coloredName = name.replace("&", "§");
            npc.setCustomName(coloredName);
            npc.setCustomNameVisible(true);

            BossBar bossBar = npcBossBars.get(npcId);
            if (bossBar != null) {
                bossBar.setTitle(coloredName);
            }
        }
    }

    public void setNPCSpeed(UUID npcId, double speed) {
        LivingEntity npc = npcs.get(npcId);
        if (npc != null) {
            if (npc.getAttribute(Attribute.MOVEMENT_SPEED) != null) {
                npc.getAttribute(Attribute.MOVEMENT_SPEED).setBaseValue(speed);
            }
        }
    }

    public void setNPCHealth(UUID npcId, double health) {
        LivingEntity npc = npcs.get(npcId);
        if (npc != null) {
            if (npc.getAttribute(Attribute.MAX_HEALTH) != null) {
                npc.getAttribute(Attribute.MAX_HEALTH).setBaseValue(health);
                npc.setHealth(health);
                updateBossBar(npcId);
            }
        }
    }

    public void setNPCWeapon(UUID npcId, ItemStack weapon) {
        LivingEntity npc = npcs.get(npcId);
        if (npc != null && npc.getEquipment() != null) {
            npc.getEquipment().setItemInMainHand(weapon.clone());
            npc.getEquipment().setItemInMainHandDropChance(0.0f);
        }
    }

    public void setNPCOffHand(UUID npcId, ItemStack item) {
        LivingEntity npc = npcs.get(npcId);
        if (npc != null && npc.getEquipment() != null) {
            npc.getEquipment().setItemInOffHand(item.clone());
            npc.getEquipment().setItemInOffHandDropChance(0.0f);
        }
    }

    public void setNPCArmor(UUID npcId, ItemStack helmet, ItemStack chestplate,
                            ItemStack leggings, ItemStack boots) {
        LivingEntity npc = npcs.get(npcId);
        if (npc != null && npc.getEquipment() != null) {
            if (helmet != null) {
                npc.getEquipment().setHelmet(helmet.clone());
                npc.getEquipment().setHelmetDropChance(0.0f);
            }
            if (chestplate != null) {
                npc.getEquipment().setChestplate(chestplate.clone());
                npc.getEquipment().setChestplateDropChance(0.0f);
            }
            if (leggings != null) {
                npc.getEquipment().setLeggings(leggings.clone());
                npc.getEquipment().setLeggingsDropChance(0.0f);
            }
            if (boots != null) {
                npc.getEquipment().setBoots(boots.clone());
                npc.getEquipment().setBootsDropChance(0.0f);
            }
        }
    }

    public void setAggroMode(UUID npcId, String mode) {
        npcAggroMode.put(npcId, mode);
    }

    public void setAggroPlayer(UUID npcId, UUID playerId) {
        npcAggroMode.put(npcId, playerId.toString());
    }

    private void updateBossBar(UUID npcId) {
        LivingEntity npc = npcs.get(npcId);
        BossBar bossBar = npcBossBars.get(npcId);

        if (npc != null && npc.isValid() && bossBar != null) {
            double maxHealth = npc.getAttribute(Attribute.MAX_HEALTH).getBaseValue();
            double currentHealth = npc.getHealth();
            double progress = currentHealth / maxHealth;

            bossBar.setProgress(Math.max(0.0, Math.min(1.0, progress)));

            if (progress > 0.5) {
                bossBar.setColor(BarColor.RED);
            } else if (progress > 0.25) {
                bossBar.setColor(BarColor.YELLOW);
            } else {
                bossBar.setColor(BarColor.RED);
            }
        }
    }

    @EventHandler
    public void onNPCDamage(EntityDamageEvent event) {
        if (event.getEntity() instanceof LivingEntity) {
            LivingEntity entity = (LivingEntity) event.getEntity();
            if (npcs.containsKey(entity.getUniqueId())) {
                Bukkit.getScheduler().runTaskLater(plugin, () -> {
                    updateBossBar(entity.getUniqueId());
                }, 1L);
            }
        }
    }

    @EventHandler
    public void onNPCDeath(EntityDeathEvent event) {
        LivingEntity entity = event.getEntity();
        UUID npcId = entity.getUniqueId();

        if (npcs.containsKey(npcId)) {
            npcs.remove(npcId);
            npcAggroMode.remove(npcId);

            BossBar bossBar = npcBossBars.remove(npcId);
            if (bossBar != null) {
                bossBar.removeAll();
            }

            event.getDrops().clear();
            event.setDroppedExp(0);
        }
    }

    private void startBossBarTask() {
        new BukkitRunnable() {
            @Override
            public void run() {
                for (Map.Entry<UUID, LivingEntity> entry : npcs.entrySet()) {
                    UUID npcId = entry.getKey();
                    LivingEntity npc = entry.getValue();
                    BossBar bossBar = npcBossBars.get(npcId);

                    if (npc == null || !npc.isValid() || bossBar == null) continue;

                    bossBar.removeAll();

                    for (Entity entity : npc.getNearbyEntities(32, 32, 32)) {
                        if (entity instanceof Player) {
                            bossBar.addPlayer((Player) entity);
                        }
                    }

                    updateBossBar(npcId);
                }
            }
        }.runTaskTimer(plugin, 0L, 10L);
    }

    private void startAggroTask() {
        new BukkitRunnable() {
            @Override
            public void run() {
                Iterator<Map.Entry<UUID, LivingEntity>> iterator = npcs.entrySet().iterator();
                while (iterator.hasNext()) {
                    Map.Entry<UUID, LivingEntity> entry = iterator.next();
                    UUID npcId = entry.getKey();
                    LivingEntity npc = entry.getValue();

                    if (!npc.isValid()) {
                        BossBar bossBar = npcBossBars.remove(npcId);
                        if (bossBar != null) bossBar.removeAll();
                        iterator.remove();
                        npcAggroMode.remove(npcId);
                        continue;
                    }

                    String aggroMode = npcAggroMode.get(npcId);
                    if (aggroMode == null) continue;

                    if (aggroMode.equals("all")) {
                        Player nearest = getNearestPlayer(npc, 16.0);
                        if (nearest != null && npc instanceof Mob) {
                            ((Mob) npc).setTarget(nearest);
                        }
                    } else if (!aggroMode.equals("none")) {
                        try {
                            UUID targetPlayerId = UUID.fromString(aggroMode);
                            Player targetPlayer = Bukkit.getPlayer(targetPlayerId);
                            if (targetPlayer != null && targetPlayer.isOnline()) {
                                if (npc.getLocation().distance(targetPlayer.getLocation()) <= 50) {
                                    if (npc instanceof Mob) {
                                        ((Mob) npc).setTarget(targetPlayer);
                                    }
                                }
                            }
                        } catch (IllegalArgumentException ignored) {}
                    }
                }
            }
        }.runTaskTimer(plugin, 0L, 20L);
    }

    private Player getNearestPlayer(LivingEntity npc, double range) {
        Player nearest = null;
        double minDistance = range;

        for (Entity entity : npc.getNearbyEntities(range, range, range)) {
            if (entity instanceof Player) {
                Player player = (Player) entity;
                double distance = npc.getLocation().distance(player.getLocation());
                if (distance < minDistance) {
                    minDistance = distance;
                    nearest = player;
                }
            }
        }

        return nearest;
    }

    public Map<UUID, LivingEntity> getAllNPCs() {
        return new HashMap<>(npcs);
    }
}


