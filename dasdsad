    public void setCenter(World w, int x, int z) {
        this.world = w;
        this.centerX = x;
        this.centerZ = z;
        saveConfig();
        startTimer();
    }

    public void setInterval(int min) {
        this.intervalMinutes = Math.max(1, min);
        saveConfig();
        if (!isActive) startTimer();
    }

    public void setGuardCount(String type, int count) {
        count = Math.max(0, Math.min(10, count));
        switch (type.toLowerCase()) {
            case "legendary": legendaryGuardCount = count; break;
            case "rare": rareGuardCount = count; break;
            default: commonGuardCount = count; break;
        }
        saveConfig();
    }

    public void setNpcPreset(String type, String name) {
        npcPresets.put(type.toLowerCase(), name);
        saveConfig();
    }

    public void setLootChance(String type, int chance) {
        AirdropLoot l = lootTypes.get(type.toLowerCase());
        if (l != null) {
            l.setChance(chance);
            saveLootConfig();
        }
    }

    public int getInterval() { return intervalMinutes; }
    public Location getCurrentLocation() { return currentLocation; }
    public boolean isAirdropActive() { return isActive; }
    public boolean isTimerRunning() { return timerTask != null && !isActive; }
    public String getCurrentLootType() { return currentType; }
    public AirdropLoot getLoot(String type) { return lootTypes.get(type.toLowerCase()); }
    public Map<String, AirdropLoot> getAllLoot() { return new HashMap<>(lootTypes); }
    public String getNpcPreset(String type) { return npcPresets.get(type.toLowerCase()); }
    public Map<String, String> getAllNpcPresets() { return new HashMap<>(npcPresets); }

    public int getGuardCount(String type) {
        switch (type.toLowerCase()) {
            case "legendary": return legendaryGuardCount;
            case "rare": return rareGuardCount;
            default: return commonGuardCount;
        }
    }

    // ========================================
    // КОНФИГ
    // ========================================

    private void loadConfig() {
        File f = new File(plugin.getDataFolder(), "airdrop.yml");
        if (!f.exists()) { saveConfig(); return; }

        FileConfiguration c = YamlConfiguration.loadConfiguration(f);
        intervalMinutes = c.getInt("interval", 20);
        centerX = c.getInt("centerX", 0);
        centerZ = c.getInt("centerZ", 0);
        radius = c.getInt("radius", 300);
        commonGuardCount = c.getInt("guards.common", 1);
        rareGuardCount = c.getInt("guards.rare", 2);
        legendaryGuardCount = c.getInt("guards.legendary", 4);

        String wName = c.getString("world");
        if (wName != null) world = Bukkit.getWorld(wName);

        if (c.contains("npcPresets")) {
            for (String t : c.getConfigurationSection("npcPresets").getKeys(false)) {
                npcPresets.put(t, c.getString("npcPresets." + t));
            }
        }
    }

    private void saveConfig() {
        File f = new File(plugin.getDataFolder(), "airdrop.yml");
        FileConfiguration c = YamlConfiguration.loadConfiguration(f);

        c.set("interval", intervalMinutes);
        c.set("centerX", centerX);
        c.set("centerZ", centerZ);
        c.set("radius", radius);
        c.set("world", world != null ? world.getName() : null);
        c.set("guards.common", commonGuardCount);
        c.set("guards.rare", rareGuardCount);
        c.set("guards.legendary", legendaryGuardCount);

        for (Map.Entry<String, String> e : npcPresets.entrySet()) {
            c.set("npcPresets." + e.getKey(), e.getValue());
        }

        try { c.save(f); } catch (IOException e) { e.printStackTrace(); }
    }

    public void saveLootConfig() {
        File f = new File(plugin.getDataFolder(), "airdrop_loot.yml");
        FileConfiguration c = YamlConfiguration.loadConfiguration(f);

        for (Map.Entry<String, AirdropLoot> e : lootTypes.entrySet()) {
            c.set(e.getKey() + ".chance", e.getValue().getChance());
            c.set(e.getKey() + ".items", e.getValue().getItems());
        }

        try { c.save(f); } catch (IOException e) { e.printStackTrace(); }
    }

    private void loadLootConfig() {
        File f = new File(plugin.getDataFolder(), "airdrop_loot.yml");
        if (!f.exists()) { saveLootConfig(); return; }

        FileConfiguration c = YamlConfiguration.loadConfiguration(f);
        for (String t : lootTypes.keySet()) {
            if (c.contains(t)) {
                AirdropLoot l = lootTypes.get(t);
                l.setChance(c.getInt(t + ".chance", l.getChance()));
                List<?> items = c.getList(t + ".items");
                if (items != null && !items.isEmpty()) {
                    l.clearItems();
                    for (Object o : items) {
                        if (o instanceof ItemStack) l.addItem((ItemStack) o);
                    }
                }
            }
        }
    }

    public void shutdown() {
        if (timerTask != null) timerTask.cancel();
        if (abilityTask != null) abilityTask.cancel();
        removeAllGuardBossBars();
        removeGuards();
        removeBeacon();
    }
}


