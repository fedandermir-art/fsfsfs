    // ========================================
    // ТАЙМЕР
    // ========================================

    private void startTimer() {
        if (timerTask != null) timerTask.cancel();
        if (world == null) return;

        secondsLeft = intervalMinutes * 60;

        timerTask = new BukkitRunnable() {
            @Override
            public void run() {
                if (isActive) return;
                secondsLeft--;
                if (secondsLeft <= 0) {
                    spawnAirdrop();
                    secondsLeft = intervalMinutes * 60;
                }
            }
        }.runTaskTimer(plugin, 20L, 20L);
    }

    public String getFormattedTime() {
        if (isActive) return "§a§lАКТИВЕН";
        if (secondsLeft <= 0) return "§cНе запущен";
        return String.format("§e%02d:%02d", secondsLeft / 60, secondsLeft % 60);
    }

    // ========================================
    // СПАВН АИРДРОПА
    // ========================================

    private void spawnAirdrop() {
        if (world == null) return;

        Location loc = findSafeLocation();
        if (loc == null) {
            loc = new Location(world, centerX, world.getHighestBlockYAt(centerX, centerZ) + 1, centerZ);
        }
        spawn(loc);
    }

    public void forceSpawn() {
        if (isActive) remove();
        if (world == null) return;
        spawnAirdrop();
    }

    public void forceSpawn(Player player) {
        if (isActive) remove();
        if (world == null) {
            world = player.getWorld();
            centerX = player.getLocation().getBlockX();
            centerZ = player.getLocation().getBlockZ();
            saveConfig();
        }
        spawnAirdrop();
    }

    public void spawnHere(Player player) {
        if (isActive) remove();
        world = player.getWorld();
        Location loc = player.getLocation();
        loc.setY(world.getHighestBlockYAt(loc.getBlockX(), loc.getBlockZ()) + 1);
        spawn(loc);
    }

    private void spawn(Location loc) {
        currentType = selectLootType();
        currentLocation = loc.clone();
        isActive = true;

        loc.getChunk().load(true);

        Material shulkerMat;
        switch (currentType) {
            case "rare": shulkerMat = Material.BLUE_SHULKER_BOX; break;
            case "legendary": shulkerMat = Material.ORANGE_SHULKER_BOX; break;
            default: shulkerMat = Material.WHITE_SHULKER_BOX; break;
        }

        currentShulkerBlock = loc.getBlock();
        currentShulkerBlock.setType(shulkerMat);

        placeBeacon(loc);
        spawnGuards(loc, currentType);
        announceSpawn(loc, lootTypes.get(currentType));
    }

    private String selectLootType() {
        int total = 0;
        for (AirdropLoot l : lootTypes.values()) total += l.getChance();
        if (total <= 0) return "common";

        int roll = random.nextInt(total);
        int sum = 0;
        for (Map.Entry<String, AirdropLoot> e : lootTypes.entrySet()) {
            sum += e.getValue().getChance();
            if (roll < sum) return e.getKey();
        }
        return "common";
    }

    private Location findSafeLocation() {
        if (world == null) return null;

        for (int i = 0; i < 50; i++) {
            int x = centerX + random.nextInt(radius * 2) - radius;
            int z = centerZ + random.nextInt(radius * 2) - radius;

            world.getChunkAt(x >> 4, z >> 4).load(true);

            int y = world.getHighestBlockYAt(x, z);
            Location loc = new Location(world, x + 0.5, y + 1, z + 0.5);
            Block below = loc.clone().subtract(0, 1, 0).getBlock();

            if (below.getType().isSolid() &&
                    below.getType() != Material.LAVA &&
                    below.getType() != Material.WATER &&
                    !below.getType().name().contains("LEAVES")) {
                return loc;
            }
        }
        return null;
    }

    private void remove() {
        if (currentShulkerBlock != null && currentShulkerBlock.getType().toString().contains("SHULKER")) {
            currentShulkerBlock.setType(Material.AIR);
        }

        removeBeacon();
        removeGuards();

        isActive = false;
        currentLocation = null;
        currentType = null;
        currentShulkerBlock = null;
        totalGuardsSpawned = 0;
    }

    public void removeAirdrop() {
        if (isActive) remove();
    }

    // ========================================
    // ДРОП ЛУТА
    // ========================================

    private void dropLoot(Location location) {
        AirdropLoot loot = lootTypes.get(currentType);
        if (loot == null) return;

        List<ItemStack> items = loot.getItems();
        if (items == null || items.isEmpty()) {
            dropItem(location, new ItemStack(Material.DIAMOND, 10));
            dropItem(location, new ItemStack(Material.GOLDEN_APPLE, 5));
            return;
        }

        List<ItemStack> shuffled = new ArrayList<>(items);
        Collections.shuffle(shuffled);

        int count = Math.min(shuffled.size(), 5 + random.nextInt(5));
        for (int i = 0; i < count; i++) {
            ItemStack item = shuffled.get(i).clone();
            if (item.getAmount() > 1) {
                item.setAmount(1 + random.nextInt(item.getAmount()));
            }
            dropItem(location, item);
        }
    }

    private void dropItem(Location location, ItemStack item) {
        Location dropLoc = location.clone().add(0, 1, 0);
        Item dropped = location.getWorld().dropItem(dropLoc, item);

        double x = (random.nextDouble() - 0.5) * 0.3;
        double y = 0.3 + random.nextDouble() * 0.2;
        double z = (random.nextDouble() - 0.5) * 0.3;
        dropped.setVelocity(new Vector(x, y, z));
    }

    // ========================================
    // МАЯК
    // ========================================

    private void placeBeacon(Location loc) {
        ironLoc = loc.clone().subtract(0, 2, 0);
        beaconLoc = loc.clone().subtract(0, 1, 0);
        ironLoc.getBlock().setType(Material.IRON_BLOCK);
        beaconLoc.getBlock().setType(Material.BEACON);
    }

    private void removeBeacon() {
        if (beaconLoc != null && beaconLoc.getBlock().getType() == Material.BEACON)
            beaconLoc.getBlock().setType(Material.AIR);
        if (ironLoc != null && ironLoc.getBlock().getType() == Material.IRON_BLOCK)
            ironLoc.getBlock().setType(Material.AIR);
        beaconLoc = null;
        ironLoc = null;
    }

    // ========================================
    // ОХРАННИКИ
    // ========================================

    private void spawnGuards(Location loc, String type) {
        removeGuards();

        int count;
        switch (type) {
            case "legendary": count = legendaryGuardCount; break;
            case "rare": count = rareGuardCount; break;
            default: count = commonGuardCount; break;
        }

        totalGuardsSpawned = count;

        String presetName = npcPresets.get(type);
        NPCPreset preset = findPreset(presetName);

        for (int i = 0; i < count; i++) {
            Location guardLoc = findGuardLocation(loc);
            if (guardLoc == null) guardLoc = loc.clone().add(2 + i * 2, 0, 2);

            LivingEntity guard = createGuard(guardLoc, preset, type);
            if (guard != null) {
                guards.add(guard);
                if (preset != null && preset.getAbilities().hasAnyAbility()) {
                    guardAbilities.put(guard.getUniqueId(), preset.getAbilities().copy());
                }
            }
        }
    }

    private NPCPreset findPreset(String name) {
        if (name == null) return null;
        for (UUID id : plugin.getPresetManager().getAllPlayerIds()) {
            NPCPreset p = plugin.getPresetManager().getPresetByName(id, name);
            if (p != null) return p;
        }
        return null;
    }

    private Location findGuardLocation(Location center) {
        for (int i = 0; i < 15; i++) {
            double angle = random.nextDouble() * Math.PI * 2;
            int dist = 3 + random.nextInt(6);
            int x = center.getBlockX() + (int)(Math.cos(angle) * dist);
            int z = center.getBlockZ() + (int)(Math.sin(angle) * dist);
            int y = center.getWorld().getHighestBlockYAt(x, z);
            Location loc = new Location(center.getWorld(), x + 0.5, y + 1, z + 0.5);
            if (loc.getBlock().getType() == Material.AIR) return loc;
        }
        return null;
    }

    private LivingEntity createGuard(Location loc, NPCPreset preset, String type) {
        String mobType = preset != null ? preset.getMobType() : "zombie";
        LivingEntity entity;

        switch (mobType.toLowerCase()) {
            case "skeleton":
                Skeleton sk = loc.getWorld().spawn(loc, Skeleton.class);
                sk.setShouldBurnInDay(false);
                entity = sk;
                break;
            case "wither_skeleton":
            case "wither":
                entity = loc.getWorld().spawn(loc, WitherSkeleton.class);
                break;
            case "piglin_brute":
                entity = loc.getWorld().spawn(loc, PiglinBrute.class);
                break;
            default:
                Zombie z = loc.getWorld().spawn(loc, Zombie.class);
                z.setShouldBurnInDay(false);
                z.setAdult();
                entity = z;
                break;
        }

        entity.setRemoveWhenFarAway(false);
        entity.setPersistent(true);
        entity.setCustomNameVisible(true);

        if (preset != null) {
            applyPreset(entity, preset);
        } else {
            applyDefaultStats(entity, type);
        }

        // Создаём BossBar для охранника
        createGuardBossBar(entity);

        return entity;
    }

    private void applyPreset(LivingEntity entity, NPCPreset preset) {
        entity.setCustomName(preset.getDisplayName().replace("&", "§"));

        if (entity.getAttribute(Attribute.MAX_HEALTH) != null) {
            entity.getAttribute(Attribute.MAX_HEALTH).setBaseValue(preset.getHealth());
            entity.setHealth(preset.getHealth());
        }
        if (entity.getAttribute(Attribute.MOVEMENT_SPEED) != null) {
            entity.getAttribute(Attribute.MOVEMENT_SPEED).setBaseValue(preset.getSpeed());
        }

        if (entity.getEquipment() != null) {
            if (preset.getWeapon() != null) {
                entity.getEquipment().setItemInMainHand(preset.getWeapon().clone());
                entity.getEquipment().setItemInMainHandDropChance(0f);
            }
            if (preset.getHelmet() != null) {
                entity.getEquipment().setHelmet(preset.getHelmet().clone());
                entity.getEquipment().setHelmetDropChance(0f);
            }
            if (preset.getChestplate() != null) {
                entity.getEquipment().setChestplate(preset.getChestplate().clone());
                entity.getEquipment().setChestplateDropChance(0f);
            }
            if (preset.getLeggings() != null) {
                entity.getEquipment().setLeggings(preset.getLeggings().clone());
                entity.getEquipment().setLeggingsDropChance(0f);
            }
            if (preset.getBoots() != null) {
                entity.getEquipment().setBoots(preset.getBoots().clone());
                entity.getEquipment().setBootsDropChance(0f);
            }
        }
    }

    private void applyDefaultStats(LivingEntity entity, String type) {
        AirdropLoot loot = lootTypes.get(type);
        entity.setCustomName(loot.getColor() + "§lОхранник Аирдропа");

        double health;
        switch (type) {
            case "legendary": health = 80; break;
            case "rare": health = 50; break;
            default: health = 30; break;
        }

        if (entity.getAttribute(Attribute.MAX_HEALTH) != null) {
            entity.getAttribute(Attribute.MAX_HEALTH).setBaseValue(health);
            entity.setHealth(health);
        }
    }

    private void removeGuards() {
        removeAllGuardBossBars();

        for (LivingEntity g : guards) {
            if (g != null && g.isValid()) g.remove();
        }
        guards.clear();
        guardAbilities.clear();
        lastTnt.clear();
        lastLightning.clear();
        lastLaunch.clear();
    }

    private void cleanupGuards() {
        guards.removeIf(g -> g == null || !g.isValid() || g.isDead());
    }

    public int getAliveGuardsCount() {
        cleanupGuards();
        return guards.size();
    }

    public boolean hasAliveGuards() {
        cleanupGuards();
        return !guards.isEmpty();
    }

    // ========================================
    // BOSS BAR ДЛЯ ОХРАННИКОВ (HP)
    // ========================================

    private void createGuardBossBar(LivingEntity guard) {
        String name = guard.getCustomName() != null ? guard.getCustomName() : "§cОхранник";
        double maxHealth = guard.getAttribute(Attribute.MAX_HEALTH).getValue();

        BarColor color;
        switch (currentType) {
            case "legendary": color = BarColor.YELLOW; break;
            case "rare": color = BarColor.BLUE; break;
            default: color = BarColor.RED; break;
        }

        BossBar bossBar = Bukkit.createBossBar(
                name + " §c❤ " + (int) guard.getHealth() + "/" + (int) maxHealth,
                color,
                BarStyle.SOLID
        );

        bossBar.setProgress(1.0);
        bossBar.setVisible(true);

        for (Player player : Bukkit.getOnlinePlayers()) {
            bossBar.addPlayer(player);
        }

        guardBossBars.put(guard.getUniqueId(), bossBar);
    }

    private void updateGuardBossBar(LivingEntity guard) {
        BossBar bossBar = guardBossBars.get(guard.getUniqueId());
        if (bossBar == null) return;

        double maxHealth = guard.getAttribute(Attribute.MAX_HEALTH).getValue();
        double health = guard.getHealth();
        double progress = health / maxHealth;

        String name = guard.getCustomName() != null ? guard.getCustomName() : "§cОхранник";
        bossBar.setTitle(name + " §c❤ " + (int) health + "/" + (int) maxHealth);
        bossBar.setProgress(Math.max(0.0, Math.min(1.0, progress)));

        if (progress > 0.5) {
            bossBar.setColor(BarColor.GREEN);
        } else if (progress > 0.25) {
            bossBar.setColor(BarColor.YELLOW);
        } else {
            bossBar.setColor(BarColor.RED);
        }
    }

    private void removeGuardBossBar(UUID guardId) {
        BossBar bossBar = guardBossBars.remove(guardId);
        if (bossBar != null) {
            bossBar.setVisible(false);
            bossBar.removeAll();
        }
    }

    private void removeAllGuardBossBars() {
        for (BossBar bossBar : guardBossBars.values()) {
            bossBar.setVisible(false);
            bossBar.removeAll();
        }
        guardBossBars.clear();
    }

