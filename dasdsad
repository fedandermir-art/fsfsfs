        rare.addItem(new ItemStack(Material.GOLDEN_APPLE, 8));
        rare.addItem(new ItemStack(Material.ENCHANTED_GOLDEN_APPLE, 2));
        rare.addItem(new ItemStack(Material.NETHERITE_SCRAP, 4));
        rare.addItem(new ItemStack(Material.TOTEM_OF_UNDYING, 1));
        rare.addItem(new ItemStack(Material.DIAMOND_BLOCK, 6));
        lootTypes.put("rare", rare);

        AirdropLoot legendary = new AirdropLoot("legendary", 10);
        legendary.addItem(new ItemStack(Material.NETHERITE_INGOT, 4));
        legendary.addItem(new ItemStack(Material.ENCHANTED_GOLDEN_APPLE, 8));
        legendary.addItem(new ItemStack(Material.TOTEM_OF_UNDYING, 2));
        legendary.addItem(new ItemStack(Material.ELYTRA, 1));
        legendary.addItem(new ItemStack(Material.DIAMOND_BLOCK, 8));
        legendary.addItem(new ItemStack(Material.BEACON, 1));
