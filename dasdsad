    // СОБЫТИЯ
    // ========================================

    @EventHandler(priority = EventPriority.HIGHEST)
    public void onPlayerInteract(PlayerInteractEvent event) {
        if (!isActive || currentLocation == null) return;
        if (event.getClickedBlock() == null) return;

        Block clicked = event.getClickedBlock();
        if (!clicked.getType().toString().contains("SHULKER")) return;
        if (!isSameLocation(clicked.getLocation(), currentLocation)) return;

        Player player = event.getPlayer();
        event.setCancelled(true);

        cleanupGuards();

        if (hasAliveGuards()) {
            player.sendMessage("§c§l✘ Убей охранников! §7(" + guards.size() + ")");
            player.playSound(player.getLocation(), Sound.ENTITY_VILLAGER_NO, 1f, 1f);
            return;
        }

        dropLoot(currentLocation);
        player.playSound(currentLocation, Sound.BLOCK_CHEST_OPEN, 1f, 1f);
        handleAirdropTaken(player);
    }

    @EventHandler(priority = EventPriority.HIGHEST)
    public void onBlockBreak(BlockBreakEvent event) {
        if (!isActive || currentLocation == null) return;
        if (!event.getBlock().getType().toString().contains("SHULKER")) return;
        if (!isSameLocation(event.getBlock().getLocation(), currentLocation)) return;

        Player player = event.getPlayer();
        event.setCancelled(true);

        cleanupGuards();

        if (hasAliveGuards()) {
            player.sendMessage("§c§l✘ Убей охранников! §7(" + guards.size() + ")");
            return;
        }

        dropLoot(currentLocation);
        handleAirdropTaken(player);
    }

    @EventHandler
    public void onGuardDamage(EntityDamageEvent event) {
        if (!isActive) return;
        if (!(event.getEntity() instanceof LivingEntity)) return;

        LivingEntity entity = (LivingEntity) event.getEntity();
        if (!guards.contains(entity)) return;

        Bukkit.getScheduler().runTaskLater(plugin, () -> {
            if (entity.isValid() && !entity.isDead()) {
                updateGuardBossBar(entity);
            }
        }, 1L);
    }

    @EventHandler
    public void onGuardDeath(EntityDeathEvent event) {
        if (!isActive) return;

        LivingEntity entity = event.getEntity();
        if (!guards.contains(entity)) return;

        removeGuardBossBar(entity.getUniqueId());
        guards.remove(entity);
        guardAbilities.remove(entity.getUniqueId());

        event.getDrops().clear();
        event.setDroppedExp(10 + random.nextInt(20));

        if (guards.isEmpty()) {
            for (Player p : Bukkit.getOnlinePlayers()) {
                p.sendMessage("§6§l[АИРДРОП] §aОхранники убиты! Забирай лут!");
                p.playSound(p.getLocation(), Sound.ENTITY_PLAYER_LEVELUP, 1f, 1f);
            }
        }
    }

    @EventHandler
    public void onPlayerJoin(PlayerJoinEvent event) {
        if (!isActive) return;

        Bukkit.getScheduler().runTaskLater(plugin, () -> {
            Player player = event.getPlayer();
            if (!player.isOnline()) return;

            for (BossBar bossBar : guardBossBars.values()) {
                bossBar.addPlayer(player);
            }
        }, 20L);
    }

    @EventHandler
    public void onPlayerQuit(PlayerQuitEvent event) {
        for (BossBar bossBar : guardBossBars.values()) {
            bossBar.removePlayer(event.getPlayer());
        }
    }

    private void handleAirdropTaken(Player player) {
        AirdropLoot loot = lootTypes.get(currentType);
        String name = loot != null ? loot.getDisplayName() : "§7Обычный";

        for (Player p : Bukkit.getOnlinePlayers()) {
            p.sendMessage("§6§l[АИРДРОП] " + name + " §eзабрал §f" + player.getName());
            p.playSound(p.getLocation(), Sound.UI_TOAST_CHALLENGE_COMPLETE, 1f, 1f);
        }

        remove();
        startTimer();
    }

    private boolean isSameLocation(Location a, Location b) {
        return a.getWorld().equals(b.getWorld()) &&
                a.getBlockX() == b.getBlockX() &&
                a.getBlockY() == b.getBlockY() &&
                a.getBlockZ() == b.getBlockZ();
    }

    private void announceSpawn(Location loc, AirdropLoot loot) {
        for (Player p : Bukkit.getOnlinePlayers()) {
            p.sendMessage("");
            p.sendMessage("§6§l▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬");
            p.sendMessage(loot.getColor() + "§l  ⬇ " + loot.getDisplayName().substring(2).toUpperCase() + " АИРДРОП");
            p.sendMessage("§6  X:" + loc.getBlockX() + " Y:" + loc.getBlockY() + " Z:" + loc.getBlockZ());
            if (!guards.isEmpty()) p.sendMessage("§6  Охранников: §c" + guards.size());
            p.sendMessage("§6§l▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬");
            p.playSound(p.getLocation(), Sound.ENTITY_ENDER_DRAGON_GROWL, 1f, 1f);
            p.sendTitle(loot.getColor() + "§lАИРДРОП", "§eX:" + loc.getBlockX() + " Z:" + loc.getBlockZ(), 10, 70, 20);
        }
    }

