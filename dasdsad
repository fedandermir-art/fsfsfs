                        "",
                        "§eНажми чтобы настроить"
                ));
        inv.setItem(11, commonItem);

        // Редкий
        ItemStack rareItem = createItem(Material.GOLD_INGOT, "§9§lРедкий лут",
                Arrays.asList(
                        "§7Шанс: §f" + rare.getChance() + "%",
                        "§7Предметов: §f" + rare.getItems().size(),
                        "",
                        "§eНажми чтобы настроить"
                ));
        inv.setItem(13, rareItem);

        // Легендарный
        ItemStack legendaryItem = createItem(Material.DIAMOND, "§6§lЛегендарный лут",
                Arrays.asList(
                        "§7Шанс: §f" + legendary.getChance() + "%",
                        "§7Предметов: §f" + legendary.getItems().size(),
                        "",
                        "§eНажми чтобы настроить"
                ));
        inv.setItem(15, legendaryItem);

        // Инфо
        int total = common.getChance() + rare.getChance() + legendary.getChance();
        ItemStack infoItem = createItem(Material.BOOK, "§e§lИнформация",
                Arrays.asList(
                        "§7Сумма шансов: §f" + total + "%",
                        "",
                        "§7Шанс выбирается случайно",
                        "§7из 100%. Если сумма > 100%,",
                        "§7то шансы пропорциональны."
                ));
        inv.setItem(22, infoItem);

        // Заполнитель
        ItemStack filler = createItem(Material.GRAY_STAINED_GLASS_PANE, " ", null);
        for (int i = 0; i < 27; i++) {
            if (inv.getItem(i) == null) {
                inv.setItem(i, filler);
            }
        }

        player.openInventory(inv);
    }

    public void openLootMenu(Player player, String type) {
        String title;
        switch (type) {
            case "common":
                title = COMMON_MENU;
                break;
            case "rare":
                title = RARE_MENU;
                break;
            case "legendary":
                title = LEGENDARY_MENU;
                break;
            default:
                return;
        }

        Inventory inv = Bukkit.createInventory(null, 54, title);
        AirdropLoot loot = airdropManager.getLoot(type);

        // Заполняем предметы (слоты 0-26)
        List<ItemStack> items = loot.getItems();
        for (int i = 0; i < items.size() && i < 27; i++) {
            inv.setItem(i, items.get(i));
        }

        // Нижняя панель
        ItemStack filler = createItem(Material.GRAY_STAINED_GLASS_PANE, " ", null);
        for (int i = 27; i < 54; i++) {
            inv.setItem(i, filler);
        }

        // Кнопка сохранить
        ItemStack saveBtn = createItem(Material.EMERALD_BLOCK, "§a§lСохранить",
                Collections.singletonList("§7Сохранить изменения"));
        inv.setItem(49, saveBtn);

        // Кнопка назад
        ItemStack backBtn = createItem(Material.ARROW, "§c§lНазад",
                Collections.singletonList("§7В главное меню"));
        inv.setItem(45, backBtn);

        // Кнопка очистить
        ItemStack clearBtn = createItem(Material.BARRIER, "§c§lОчистить всё",
                Collections.singletonList("§7Удалить все предметы"));
        inv.setItem(53, clearBtn);

        // Инфо
        ItemStack infoBtn = createItem(Material.BOOK, "§e§lКак добавить предметы",
                Arrays.asList(
                        "§7Просто перетащи предметы",
                        "§7из своего инвентаря в верхнюю",
                        "§7часть меню (27 слотов)",
                        "",
                        "§7Потом нажми §aСохранить"
                ));
        inv.setItem(47, infoBtn);

        // Шанс
        ItemStack chanceBtn = createItem(Material.CLOCK, "§b§lШанс: " + loot.getChance() + "%",
                Arrays.asList(
                        "§7Текущий шанс выпадения",
                        "",
                        "§7Изменить командой:",
                        "§e/airdropchance " + type + " <число>"
                ));
        inv.setItem(51, chanceBtn);

        editingType.put(player.getUniqueId(), type);
        player.openInventory(inv);
    }

    @EventHandler
    public void onInventoryClick(InventoryClickEvent event) {
        if (!(event.getWhoClicked() instanceof Player)) return;
        Player player = (Player) event.getWhoClicked();
        String title = event.getView().getTitle();

        if (title.equals(MAIN_MENU)) {
            event.setCancelled(true);
            handleMainMenuClick(player, event.getSlot());
        } else if (title.equals(COMMON_MENU) || title.equals(RARE_MENU) || title.equals(LEGENDARY_MENU)) {
            handleLootMenuClick(player, event);
        }
    }

    @EventHandler
    public void onInventoryClose(InventoryCloseEvent event) {
        if (!(event.getPlayer() instanceof Player)) return;
        Player player = (Player) event.getPlayer();
        editingType.remove(player.getUniqueId());
    }

    private void handleMainMenuClick(Player player, int slot) {
        switch (slot) {
            case 11:
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openLootMenu(player, "common"), 1L);
                break;
            case 13:
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openLootMenu(player, "rare"), 1L);
                break;
            case 15:
                player.closeInventory();
                Bukkit.getScheduler().runTaskLater(plugin, () -> openLootMenu(player, "legendary"), 1L);
                break;
        }
    }

    private void handleLootMenuClick(Player player, InventoryClickEvent event) {
        int slot = event.getRawSlot();

        // Разрешаем перетаскивание в верхние 27 слотов
        if (slot >= 0 && slot < 27) {
            return; // Не отменяем - можно класть предметы
        }

        // Нижняя панель
        if (slot >= 27 && slot < 54) {
            event.setCancelled(true);

            String type = editingType.get(player.getUniqueId());
            if (type == null) return;

            switch (slot) {
                case 45: // Назад
                    player.closeInventory();
                    Bukkit.getScheduler().runTaskLater(plugin, () -> openMainMenu(player), 1L);
                    break;

                case 49: // Сохранить
                    saveLootFromInventory(player, type, event.getInventory());
                    player.sendMessage("§aЛут сохранен!");
                    player.closeInventory();
                    break;

                case 53: // Очистить
                    for (int i = 0; i < 27; i++) {
                        event.getInventory().setItem(i, null);
                    }
                    player.sendMessage("§cЛут очищен! Нажми §aСохранить§c!");
                    break;
            }
        }

        // Инвентарь игрока - разрешаем
        if (slot >= 54) {
            return;
        }
    }

    private void saveLootFromInventory(Player player, String type, Inventory inv) {
        AirdropLoot loot = airdropManager.getLoot(type);
        loot.clearItems();

        for (int i = 0; i < 27; i++) {
            ItemStack item = inv.getItem(i);
            if (item != null && item.getType() != Material.AIR) {
                loot.addItem(item);
            }
        }

        airdropManager.saveLootConfig();
    }

    private ItemStack createItem(Material material, String name, List<String> lore) {
        ItemStack item = new ItemStack(material);
        ItemMeta meta = item.getItemMeta();
        if (meta != null) {
            meta.setDisplayName(name);
            if (lore != null) {
                meta.setLore(lore);
            }
            item.setItemMeta(meta);
        }
        return item;
    }
}


