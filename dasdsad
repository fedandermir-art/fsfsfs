    private void startAbilityChecker() {
        if (abilityTask != null) abilityTask.cancel();

        abilityTask = new BukkitRunnable() {
            @Override
            public void run() {
                if (!isActive || guards.isEmpty()) return;

                long now = System.currentTimeMillis();
                for (LivingEntity guard : new ArrayList<>(guards)) {
                    if (guard == null || !guard.isValid() || guard.isDead()) continue;

                    NPCAbilities ab = guardAbilities.get(guard.getUniqueId());
                    if (ab == null || !ab.hasAnyAbility()) continue;

                    Player target = findNearestPlayer(guard, ab.getActivationRadius());
                    if (target == null) continue;

                    if (ab.isTntEnabled()) {
                        long last = lastTnt.getOrDefault(guard.getUniqueId(), 0L);
                        if (now - last >= ab.getTntInterval() * 1000L) {
                            useTntAbility(guard, ab);
                            lastTnt.put(guard.getUniqueId(), now);
                        }
                    }

                    if (ab.isLightningEnabled()) {
                        long last = lastLightning.getOrDefault(guard.getUniqueId(), 0L);
                        if (now - last >= ab.getLightningInterval() * 1000L) {
                            useLightningAbility(guard, target);
                            lastLightning.put(guard.getUniqueId(), now);
                        }
                    }

                    if (ab.isLaunchEnabled()) {
                        long last = lastLaunch.getOrDefault(guard.getUniqueId(), 0L);
                        if (now - last >= ab.getLaunchInterval() * 1000L) {
                            useLaunchAbility(target, ab.getLaunchHeight());
                            lastLaunch.put(guard.getUniqueId(), now);
                        }
                    }
                }
            }
        }.runTaskTimer(plugin, 20L, 20L);
    }

    private Player findNearestPlayer(LivingEntity npc, int radius) {
        for (Entity e : npc.getNearbyEntities(radius, radius, radius)) {
            if (e instanceof Player) {
                Player p = (Player) e;
                if (p.getGameMode() == GameMode.SURVIVAL || p.getGameMode() == GameMode.ADVENTURE) {
                    return p;
                }
            }
        }
        return null;
    }

    private void useTntAbility(LivingEntity guard, NPCAbilities ab) {
        int count = ab.getTntMinCount() + random.nextInt(ab.getTntMaxCount() - ab.getTntMinCount() + 1);
        guard.getWorld().playSound(guard.getLocation(), Sound.ENTITY_CREEPER_PRIMED, 1f, 1f);

        for (int i = 0; i < count; i++) {
            Bukkit.getScheduler().runTaskLater(plugin, () -> {
                if (!guard.isValid()) return;
                TNTPrimed tnt = guard.getWorld().spawn(guard.getLocation().add(0, 1.5, 0), TNTPrimed.class);
                double angle = random.nextDouble() * Math.PI * 2;
                tnt.setVelocity(new Vector(Math.cos(angle) * 0.5, 0.5, Math.sin(angle) * 0.5));
                tnt.setFuseTicks(40 + random.nextInt(20));
            }, i * 5L);
        }
    }

    private void useLightningAbility(LivingEntity guard, Player target) {
        target.sendMessage("§e§l⚡ Молния!");
        target.getWorld().playSound(target.getLocation(), Sound.ENTITY_LIGHTNING_BOLT_THUNDER, 0.5f, 2f);
        Bukkit.getScheduler().runTaskLater(plugin, () -> {
            if (target.isOnline()) target.getWorld().strikeLightning(target.getLocation());
        }, 20L);
    }

    private void useLaunchAbility(Player target, int height) {
        target.sendMessage("§b§l⬆ Подброс!");
        Bukkit.getScheduler().runTaskLater(plugin, () -> {
            if (target.isOnline()) {
                target.setVelocity(new Vector(0, Math.min(Math.sqrt(0.2 * height), 4), 0));
                target.playSound(target.getLocation(), Sound.ENTITY_FIREWORK_ROCKET_LAUNCH, 1f, 1f);
            }
        }, 10L);
    }

