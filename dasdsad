package org.exampl.npcplugin_shahed.commands;

import org.exampl.npcplugin_shahed.CustomNPC;
import org.exampl.npcplugin_shahed.gui.PresetGUI;
import org.exampl.npcplugin_shahed.manager.NPCManager;
import org.bukkit.Bukkit;
import org.bukkit.Material;
import org.bukkit.command.Command;
import org.bukkit.command.CommandExecutor;
import org.bukkit.command.CommandSender;
import org.bukkit.entity.LivingEntity;
import org.bukkit.entity.Player;
import org.bukkit.inventory.ItemStack;

public class NPCCommand implements CommandExecutor {

    private final CustomNPC plugin;
    private final NPCManager npcManager;
    private final PresetGUI presetGUI;

    public NPCCommand(CustomNPC plugin, NPCManager npcManager, PresetGUI presetGUI) {
        this.plugin = plugin;
        this.npcManager = npcManager;
        this.presetGUI = presetGUI;
    }

    @Override
    public boolean onCommand(CommandSender sender, Command command, String label, String[] args) {
        if (!(sender instanceof Player)) {
            sender.sendMessage("§cЭту команду может использовать только игрок!");
            return true;
        }

        Player player = (Player) sender;

        if (args.length == 0) {
            sendHelp(player);
            return true;
        }

        String subCommand = args[0].toLowerCase();

        if (subCommand.equals("spawn")) {
            handleSpawn(player, args);
        } else if (subCommand.equals("remove")) {
            handleRemove(player);
        } else if (subCommand.equals("setname")) {
            handleSetName(player, args);
        } else if (subCommand.equals("setarmor")) {
            handleSetArmor(player, args);
        } else if (subCommand.equals("setspeed")) {
            handleSetSpeed(player, args);
        } else if (subCommand.equals("sethp")) {
            handleSetHP(player, args);
        } else if (subCommand.equals("setweapon")) {
            handleSetWeapon(player);
        } else if (subCommand.equals("setoffhand")) {
            handleSetOffHand(player);
        } else if (subCommand.equals("setaggro")) {
            handleSetAggro(player, args);
        } else if (subCommand.equals("saves") || subCommand.equals("presets") || subCommand.equals("menu")) {
            presetGUI.openMainMenu(player);
        } else {
            sendHelp(player);
        }

        return true;
    }

    private void handleSpawn(Player player, String[] args) {
        String mobType = "zombie";

        if (args.length >= 2) {
            mobType = args[1].toLowerCase();
            if (!mobType.equals("zombie") && !mobType.equals("skeleton") &&
                    !mobType.equals("wither_skeleton") && !mobType.equals("wither")) {
                player.sendMessage("§cДоступные мобы: zombie, skeleton, wither_skeleton");
                return;
            }
        }

        LivingEntity npc = npcManager.spawnNPC(player.getLocation(), mobType);

        String mobName;
        switch (mobType) {
            case "skeleton":
                mobName = "Скелет";
                break;
            case "wither_skeleton":
            case "wither":
                mobName = "Визер Скелет";
                break;
            default:
                mobName = "Зомби";
                break;
        }

        player.sendMessage("§aNPC заспавнен! Тип: §e" + mobName);
        player.sendMessage("§7ID: §e" + npc.getUniqueId());
    }

    private void handleRemove(Player player) {
        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        npcManager.removeNPC(npc.getUniqueId());
        player.sendMessage("§aNPC удален!");
    }

    private void handleSetName(Player player, String[] args) {
        if (args.length < 2) {
            player.sendMessage("§cИспользование: /npc setname <имя>");
            return;
        }

        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        StringBuilder name = new StringBuilder();
        for (int i = 1; i < args.length; i++) {
            name.append(args[i]).append(" ");
        }

        npcManager.setNPCName(npc.getUniqueId(), name.toString().trim());
        player.sendMessage("§aИмя NPC изменено на: §e" + name.toString().trim());
    }

    private void handleSetArmor(Player player, String[] args) {
        if (args.length < 2) {
            player.sendMessage("§cИспользование: /npc setarmor <helmet|chestplate|leggings|boots>");
            return;
        }

        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        ItemStack item = player.getInventory().getItemInMainHand();
        if (item.getType() == Material.AIR) {
            player.sendMessage("§cВозьмите предмет в руку!");
            return;
        }

        String armorType = args[1].toLowerCase();

        if (armorType.equals("helmet")) {
            npcManager.setNPCArmor(npc.getUniqueId(), item, null, null, null);
            player.sendMessage("§aШлем установлен!");
        } else if (armorType.equals("chestplate")) {
            npcManager.setNPCArmor(npc.getUniqueId(), null, item, null, null);
            player.sendMessage("§aНагрудник установлен!");
        } else if (armorType.equals("leggings")) {
            npcManager.setNPCArmor(npc.getUniqueId(), null, null, item, null);
            player.sendMessage("§aПоножи установлены!");
        } else if (armorType.equals("boots")) {
            npcManager.setNPCArmor(npc.getUniqueId(), null, null, null, item);
            player.sendMessage("§aБотинки установлены!");
        } else {
            player.sendMessage("§cНеверный тип брони! Используй: helmet, chestplate, leggings, boots");
        }
    }

    private void handleSetSpeed(Player player, String[] args) {
        if (args.length < 2) {
            player.sendMessage("§cИспользование: /npc setspeed <скорость>");
            return;
        }

        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        try {
            double speed = Double.parseDouble(args[1]);
            npcManager.setNPCSpeed(npc.getUniqueId(), speed);
            player.sendMessage("§aСкорость NPC установлена на: §e" + speed);
        } catch (NumberFormatException e) {
            player.sendMessage("§cНеверное число!");
        }
    }

    private void handleSetHP(Player player, String[] args) {
        if (args.length < 2) {
            player.sendMessage("§cИспользование: /npc sethp <здоровье>");
            return;
        }

        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        try {
            double hp = Double.parseDouble(args[1]);
            npcManager.setNPCHealth(npc.getUniqueId(), hp);
            player.sendMessage("§aЗдоровье NPC установлено на: §e" + hp);
        } catch (NumberFormatException e) {
            player.sendMessage("§cНеверное число!");
        }
    }

    private void handleSetWeapon(Player player) {
        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        ItemStack weapon = player.getInventory().getItemInMainHand();
        if (weapon.getType() == Material.AIR) {
            player.sendMessage("§cВозьмите оружие в руку!");
            return;
        }

        npcManager.setNPCWeapon(npc.getUniqueId(), weapon);
        player.sendMessage("§aОружие NPC установлено (правая рука)!");
    }

    private void handleSetOffHand(Player player) {
        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        ItemStack item = player.getInventory().getItemInMainHand();
        if (item.getType() == Material.AIR) {
            player.sendMessage("§cВозьмите предмет в руку!");
            return;
        }

        npcManager.setNPCOffHand(npc.getUniqueId(), item);
        player.sendMessage("§aПредмет установлен в левую руку NPC!");
    }

    private void handleSetAggro(Player player, String[] args) {
        if (args.length < 2) {
            player.sendMessage("§cИспользование: /npc setaggro <all|none|ник_игрока>");
            return;
        }

        LivingEntity npc = npcManager.getNearestNPC(player);
        if (npc == null) {
            player.sendMessage("§cРядом нет NPC!");
            return;
        }

        if (args[1].equalsIgnoreCase("all")) {
            npcManager.setAggroMode(npc.getUniqueId(), "all");
            player.sendMessage("§aNPC теперь агрится на всех игроков!");
        } else if (args[1].equalsIgnoreCase("none")) {
            npcManager.setAggroMode(npc.getUniqueId(), "none");
            player.sendMessage("§aNPC теперь не агрится!");
        } else {
            Player targetPlayer = Bukkit.getPlayer(args[1]);
            if (targetPlayer == null) {
                player.sendMessage("§cИгрок не найден!");
                return;
            }
            npcManager.setAggroPlayer(npc.getUniqueId(), targetPlayer.getUniqueId());
            player.sendMessage("§aNPC теперь агрится только на: §e" + targetPlayer.getName());
        }
    }

    private void sendHelp(Player player) {
        player.sendMessage("§6§l========= CustomNPC =========");
        player.sendMessage("§e/npc spawn [тип] §7- Заспавнить NPC");
        player.sendMessage("§7  Типы: §fzombie§7, §fskeleton§7, §fwither_skeleton");
        player.sendMessage("§e/npc remove §7- Удалить ближайшего NPC");
        player.sendMessage("§e/npc setname <имя> §7- Установить имя");
        player.sendMessage("§e/npc setarmor <тип> §7- Установить броню");
        player.sendMessage("§e/npc setspeed <число> §7- Установить скорость");
        player.sendMessage("§e/npc sethp <число> §7- Установить здоровье");
        player.sendMessage("§e/npc setweapon §7- Оружие (правая рука)");
        player.sendMessage("§e/npc setoffhand §7- Предмет (левая рука)");
        player.sendMessage("§e/npc setaggro <all|none|ник> §7- Агрессия");
        player.sendMessage("§e/npc saves §7- §6§lМеню пресетов");
        player.sendMessage("§6§l==============================");
    }
}


